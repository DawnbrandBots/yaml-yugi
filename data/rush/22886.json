{"konami_id": 22886, "name": {"en": "Post-Stellar Shower Princess Cosmos", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "<ruby>\u5b99<rt>\u3086</rt></ruby><ruby>\u4e0a<rt>\u3042</rt></ruby>\u304c\u308a\u30b3\u30b9\u30e2\u30b9<ruby>\u59eb<rt>\u3072\u3081</rt></ruby>", "ja_romaji": "Yuagari Kosumosu-hime", "ko": "\uc6b0\uc8fc\ubf40\uc1a1 \ucf54\uc2a4\ubaa8\uc2a4 \uacf5\uc8fc", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "summoning_condition": {"en": "This card's name becomes \"Princess Cosmos' Jest\" while in the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u5893\u5730\u306b\u3042\u308b\u3053\u306e\u30ab\u30fc\u30c9\u306e\u30ab\u30fc\u30c9\u540d\u306f\u300c\u30b3\u30b9\u30e2\u30b9\u59eb\u306e\u304a\u622f\u308c\u300d\u306b\u306a\u308b\u3002", "ko": "\ubb18\uc9c0\uc5d0 \uc788\ub294 \uc774 \uce74\ub4dc\uc758 \uce74\ub4dc\uba85\uc740 \"\ucf54\uc2a4\ubaa8\uc2a4 \uacf5\uc8fc\uc758 \uc7a5\ub09c\"\uc774 \ub41c\ub2e4.", "zh-TW": null, "zh-CN": null}, "requirement": {"en": "During a turn you have not activated \"Post-Stellar Shower Princess Cosmos\".", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u304c\u300c\u5b99\u4e0a\u304c\u308a\u30b3\u30b9\u30e2\u30b9\u59eb\u300d\u3092\u767a\u52d5\u3057\u3066\u3044\u306a\u3044\u30bf\u30fc\u30f3\u306b\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0\uc774 \"\uc6b0\uc8fc\ubf40\uc1a1 \ucf54\uc2a4\ubaa8\uc2a4 \uacf5\uc8fc\"\ub97c \ubc1c\ub3d9\ud558\uace0 \uc788\uc9c0 \uc54a\uc740 \ud134\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Send the top 2 cards of your Deck to the Graveyard. Then, you can Special Summon 1 Level 9 Galaxy Type non-Fusion Monster from your hand or Graveyard to your field in face-up Defense Position.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306e\u30c7\u30c3\u30ad\u306e\u4e0a\u304b\u3089\u30ab\u30fc\u30c9\uff12\u679a\u3092\u5893\u5730\u3078\u9001\u308b\u3002\u305d\u306e\u5f8c\u3001\u30d5\u30e5\u30fc\u30b8\u30e7\u30f3\u30e2\u30f3\u30b9\u30bf\u30fc\u4ee5\u5916\u306e\u81ea\u5206\u306e\u624b\u672d\u30fb\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30ec\u30d9\u30eb\uff19\uff0f\u30ae\u30e3\u30e9\u30af\u30b7\u30fc\u65cf\uff09\uff11\u4f53\u3092\u9078\u3093\u3067\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u8868\u5074\u5b88\u5099\u8868\u793a\u3067\u7279\u6b8a\u53ec\u559a\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0\uc758 \ub371 \uc704\uc5d0\uc11c \uce74\ub4dc 2\uc7a5\uc744 \ubb18\uc9c0\ub85c \ubcf4\ub0b8\ub2e4. \uadf8 \ud6c4, \ud4e8\uc804 \ubaac\uc2a4\ud130 \uc774\uc678\uc758 \uc790\uc2e0\uc758 \ud328 / \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130(\ub808\ubca8 9 / \uac24\ub7ed\uc2dc\uc871) 1\uc7a5\uc744 \uace0\ub974\uace0 \uc790\uc2e0 \ud544\ub4dc\uc5d0 \uc55e\uba74 \uc218\ube44 \ud45c\uc2dc\ub85c \ud2b9\uc218 \uc18c\ud658\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Spell", "property": "Normal", "series": ["Princess Cosmos"], "images": [{"index": 1, "image": "PostStellarShowerPrincessCosmos-RDKP24-JP-UR.png", "illustration": "PostStellarShowerPrincessCosmos-OW.png"}, {"index": 2, "image": "PostStellarShowerPrincessCosmos-RDKP24-JP-ORR-AA.png"}], "sets": {"ja": [{"set_number": "RD/KP24-JP056", "set_name": "Overforce of the Abyss", "rarities": ["Ultra Rare", "Secret Rare", "Over Rush Rare"]}], "ko": [{"set_number": "RD/KP24-KR056", "set_name": "Overforce of the Abyss", "rarities": ["Ultra Rare", "Secret Rare", "Over Rush Rare"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1163492}