{"konami_id": 22451, "name": {"en": "Draconic Fruits", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30c9\u30e9\u30b3\u30cb\u30c3\u30af\u30fb\u30d5\u30eb\u30fc\u30c4", "ja_romaji": "Dorakonikku Fur\u016btsu", "ko": "\ub4dc\ub77c\ucf54\ub2c9 \ud6c4\ub974\uce20", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "You have a monster on your field.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u30e2\u30f3\u30b9\u30bf\u30fc\u304c\u3044\u308b\u5834\u5408\u306b\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0 \ud544\ub4dc\uc5d0 \ubaac\uc2a4\ud130\uac00 \uc788\uc744 \uacbd\uc6b0\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Special Summon 1 Dragon Type monster with 0 ATK/1400 DEF from your Graveyard face-up to your field. If you Special Summoned \"Draco the Rider\" by this effect, send 1 other monster from your field to the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306e\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30c9\u30e9\u30b4\u30f3\u65cf\uff0f\u653b\u6483\u529b\uff10\uff0f\u5b88\u5099\u529b\uff11\uff14\uff10\uff10\uff09\uff11\u4f53\u3092\u9078\u3073\u3001\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u8868\u5074\u8868\u793a\u3067\u7279\u6b8a\u53ec\u559a\u3059\u308b\u3002\u3053\u306e\u52b9\u679c\u3067\u300c\u80cc\u4e57\u308a\u30c9\u30e9\u30b3\u300d\u3092\u7279\u6b8a\u53ec\u559a\u3057\u305f\u5834\u5408\u3001\u3055\u3089\u306b\u305d\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u4ee5\u5916\u306e\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3092\u9078\u3093\u3067\u5893\u5730\u3078\u9001\u308b\u3002", "ko": "\uc790\uc2e0 \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130(\ub4dc\ub798\uace4\uc871 / \uacf5\uaca9\ub825 0 / \uc218\ube44\ub825 1400) 1\uc7a5\uc744 \uace0\ub974\uace0, \uc790\uc2e0 \ud544\ub4dc\uc5d0 \uc55e\uba74 \ud45c\uc2dc\ub85c \ud2b9\uc218 \uc18c\ud658\ud55c\ub2e4. \uc774 \ud6a8\uacfc\ub85c \"\uc138\ub178\ub9ac \ub4dc\ub77c\ucf54\"\ub97c \ud2b9\uc218 \uc18c\ud658\ud588\uc744 \uacbd\uc6b0, \ucd94\uac00\ub85c \uadf8 \ubaac\uc2a4\ud130 \uc774\uc678\uc758 \uc790\uc2e0 \ud544\ub4dc\uc758 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \uace0\ub974\uace0 \ubb18\uc9c0\ub85c \ubcf4\ub0b8\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Spell", "property": "Normal", "series": ["Draco"], "images": [{"index": 1, "image": "DraconicFruits-RDKP23-JP-C.png"}], "sets": {"ja": [{"set_number": "RD/KP23-JP046", "set_name": "Gias Charge of the Nova", "rarities": ["Common"]}], "ko": [{"set_number": "RD/KP23-KR046", "set_name": "Gias Charge of the Nova", "rarities": ["Common"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1152718}