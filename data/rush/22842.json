{"konami_id": 22842, "name": {"en": "Moonforce Rifet", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30e0\u30fc\u30f3\u30d5\u30a9\u30fc\u30b9\u30fb\u30ea\u30d5\u30a7\u30c3\u30c8", "ja_romaji": "M\u016bnf\u014dsu Rifetto", "ko": "\ubb38\ud3ec\uc2a4 \ub9ac\ud3ab", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "You have 4 or less monsters in your Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306e\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u304c\uff14\u4f53\u4ee5\u4e0b\u306e\u5834\u5408\u306b\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0 \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130\uac00 4\uc7a5 \uc774\ud558\uc77c \uacbd\uc6b0\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Send the top 2 cards of your opponent's Deck to the Graveyard. Then, if your opponent has 5 or more monsters in their Graveyard, and you have not drawn a card during this Main Phase, you can draw 2 cards. You cannot activate monster effects until the end of this turn, except those of EARTH Attribute Galaxy Type monsters.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u76f8\u624b\u306e\u30c7\u30c3\u30ad\u306e\u4e0a\u304b\u3089\u30ab\u30fc\u30c9\uff12\u679a\u3092\u5893\u5730\u3078\u9001\u308b\u3002\u305d\u306e\u5f8c\u3001\u76f8\u624b\u306e\u5893\u5730\u306b\u30e2\u30f3\u30b9\u30bf\u30fc\u304c\uff15\u4f53\u4ee5\u4e0a\u3044\u3066\u3001\u81ea\u5206\u304c\u3053\u306e\u30e1\u30a4\u30f3\u30d5\u30a7\u30a4\u30ba\u306b\u30c9\u30ed\u30fc\u3057\u3066\u3044\u306a\u3044\u5834\u5408\u3001\u81ea\u5206\u306f\uff12\u679a\u30c9\u30ed\u30fc\u3067\u304d\u308b\u3002\u3053\u306e\u52b9\u679c\u306e\u767a\u52d5\u5f8c\u3001\u30bf\u30fc\u30f3\u7d42\u4e86\u6642\u307e\u3067\u81ea\u5206\u306f\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u5730\u5c5e\u6027\uff0f\u30ae\u30e3\u30e9\u30af\u30b7\u30fc\u65cf\uff09\u4ee5\u5916\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u306e\u52b9\u679c\u3092\u767a\u52d5\u3067\u304d\u306a\u3044\u3002", "ko": "\uc0c1\ub300\uc758 \ub371 \uc704\uc5d0\uc11c \uce74\ub4dc 2\uc7a5\uc744 \ubb18\uc9c0\ub85c \ubcf4\ub0b8\ub2e4. \uadf8 \ud6c4, \uc0c1\ub300 \ubb18\uc9c0\uc5d0 \ubaac\uc2a4\ud130\uac00 5\uc7a5 \uc774\uc0c1 \uc788\uace0, \uc790\uc2e0\uc774 \uc774 \uba54\uc778 \ud398\uc774\uc988\uc5d0 \ub4dc\ub85c\uc6b0\ud558\uace0 \uc788\uc9c0 \uc54a\uc744 \uacbd\uc6b0, \uc790\uc2e0\uc740 2\uc7a5 \ub4dc\ub85c\uc6b0\ud560 \uc218 \uc788\ub2e4. \uc774 \ud6a8\uacfc\uc758 \ubc1c\ub3d9 \ud6c4, \ud134 \uc885\ub8cc\uc2dc\uae4c\uc9c0 \uc790\uc2e0\uc740 \ubaac\uc2a4\ud130(\ub545 \uc18d\uc131 / \uac24\ub7ed\uc2dc\uc871) \uc774\uc678\uc758 \ubaac\uc2a4\ud130\uc758 \ud6a8\uacfc\ub97c \ubc1c\ub3d9\ud560 \uc218 \uc5c6\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Galaxy / Effect", "attribute": "EARTH", "level": 1, "atk": 800, "def": 800, "series": ["Moonforce"], "images": [{"index": 1, "image": "MoonforceRifet-RDKP24-JP-C.png"}], "sets": {"ja": [{"set_number": "RD/KP24-JP012", "set_name": "Overforce of the Abyss", "rarities": ["Common"]}], "ko": [{"set_number": "RD/KP24-KR012", "set_name": "Overforce of the Abyss", "rarities": ["Common"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1172956}