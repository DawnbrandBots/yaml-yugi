{"konami_id": 22426, "name": {"en": "Cosmic Sucker", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30b3\u30ba\u30df\u30c3\u30af\u30fb\u30b5\u30c3\u30ab\u30fc", "ja_romaji": "Kozumikku Sakk\u0101", "ko": "\ucf54\uc988\ubbf9 \uc11c\ucee4", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "Your LP are lower than your opponent's.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306e\uff2c\uff30\u304c\u76f8\u624b\u3088\u308a\u5c11\u306a\u3044\u5834\u5408\u306b\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0\uc758 LP\uac00 \uc0c1\ub300\ubcf4\ub2e4 \uc801\uc744 \uacbd\uc6b0\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Gain 300 LP. Then, if you have not drawn a card during this Main Phase, draw 1 card. Then, if the total original Levels of the face-up monsters on your opponent's field is 30 or higher, you can gain 3000 LP.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306f\uff13\uff10\uff10\uff2c\uff30\u56de\u5fa9\u3059\u308b\u3002\u81ea\u5206\u304c\u3053\u306e\u30e1\u30a4\u30f3\u30d5\u30a7\u30a4\u30ba\u306b\u30c9\u30ed\u30fc\u3057\u3066\u3044\u306a\u3044\u5834\u5408\u3001\u3055\u3089\u306b\u81ea\u5206\u306f\uff11\u679a\u30c9\u30ed\u30fc\u3059\u308b\u3002\u76f8\u624b\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u8868\u5074\u8868\u793a\u30e2\u30f3\u30b9\u30bf\u30fc\u306e\u5143\u3005\u306e\u30ec\u30d9\u30eb\u306e\u5408\u8a08\u304c\uff13\uff10\u4ee5\u4e0a\u306e\u5834\u5408\u3001\u3055\u3089\u306b\u81ea\u5206\u306f\uff13\uff10\uff10\uff10\uff2c\uff30\u56de\u5fa9\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0\uc740 300 LP \ud68c\ubcf5\ud55c\ub2e4. \uc790\uc2e0\uc774 \uc774 \uba54\uc778 \ud398\uc774\uc988\uc5d0 \ub4dc\ub85c\uc6b0\ud558\uace0 \uc788\uc9c0 \uc54a\uc744 \uacbd\uc6b0, \ucd94\uac00\ub85c \uc790\uc2e0\uc740 1\uc7a5 \ub4dc\ub85c\uc6b0\ud55c\ub2e4. \uc0c1\ub300 \ud544\ub4dc\uc758 \uc55e\uba74 \ud45c\uc2dc \ubaac\uc2a4\ud130\uc758 \uc6d0\ub798 \ub808\ubca8\uc758 \ud569\uacc4\uac00 30 \uc774\uc0c1\uc77c \uacbd\uc6b0, \ucd94\uac00\ub85c \uc790\uc2e0\uc740 3000 LP \ud68c\ubcf5\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Galaxy / Effect", "attribute": "LIGHT", "level": 4, "atk": 1000, "def": 1000, "images": [{"index": 1, "image": "CosmicSucker-RDKP23-JP-R.png"}], "sets": {"ja": [{"set_number": "RD/KP23-JP021", "set_name": "Gias Charge of the Nova", "rarities": ["Rare", "Secret Rare"]}], "ko": [{"set_number": "RD/KP23-KR021", "set_name": "Gias Charge of the Nova", "rarities": ["Rare", "Secret Rare"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1157798}