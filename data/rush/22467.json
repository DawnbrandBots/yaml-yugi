{"konami_id": 22467, "name": {"en": "Draconic Peace Bomber", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30c9\u30e9\u30b3\u30cb\u30c3\u30af\u30fb\u30d4\u30fc\u30b9\u30dc\u30f3\u30d0\u30fc", "ja_romaji": "Dorakonikku P\u012bsu Bonb\u0101", "ko": "\ub4dc\ub77c\ucf54\ub2c9 \ud53c\uc2a4\ubd04\ubc84", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "When your opponent Sets a Spell/Trap Card during their turn.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u76f8\u624b\u30bf\u30fc\u30f3\u306b\u76f8\u624b\u304c\u9b54\u6cd5\u30fb\u7f60\u30ab\u30fc\u30c9\u3092\u30bb\u30c3\u30c8\u3057\u305f\u6642\u306b\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc0c1\ub300 \ud134\uc5d0 \uc0c1\ub300\uac00 \ub9c8\ubc95 / \ud568\uc815 \uce74\ub4dc\ub97c \uc138\ud2b8\ud588\uc744 \ub54c\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Destroy 1 face-down Spell/Trap Card on your opponent's field. Then, if your opponent has a non-Normal Spell Card in their Graveyard, you can Special Summon up to 2 monsters from your hand and/or Graveyard face-up to your field.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u76f8\u624b\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u88cf\u5074\u8868\u793a\u306e\u9b54\u6cd5\u30fb\u7f60\u30ab\u30fc\u30c9\uff11\u679a\u3092\u9078\u3093\u3067\u7834\u58ca\u3059\u308b\u3002\u305d\u306e\u5f8c\u3001\u76f8\u624b\u306e\u5893\u5730\u306b\u901a\u5e38\u9b54\u6cd5\u30ab\u30fc\u30c9\u4ee5\u5916\u306e\u9b54\u6cd5\u30ab\u30fc\u30c9\u304c\u3042\u308b\u5834\u5408\u3001\u81ea\u5206\u306e\u624b\u672d\u30fb\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\uff12\u4f53\u307e\u3067\u9078\u3093\u3067\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u8868\u5074\u8868\u793a\u3067\u7279\u6b8a\u53ec\u559a\u3067\u304d\u308b\u3002", "ko": "\uc0c1\ub300 \ud544\ub4dc\uc758 \ub4b7\uba74 \ud45c\uc2dc\uc778 \ub9c8\ubc95 / \ud568\uc815 \uce74\ub4dc 1\uc7a5\uc744 \uace0\ub974\uace0 \ud30c\uad34\ud55c\ub2e4. \uadf8 \ud6c4, \uc0c1\ub300 \ubb18\uc9c0\uc5d0 \uc77c\ubc18 \ub9c8\ubc95 \uce74\ub4dc \uc774\uc678\uc758 \ub9c8\ubc95 \uce74\ub4dc\uac00 \uc788\uc744 \uacbd\uc6b0, \uc790\uc2e0\uc758 \ud328 / \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130\ub97c 2\uc7a5\uae4c\uc9c0 \uace0\ub974\uace0 \uc790\uc2e0 \ud544\ub4dc\uc5d0 \uc55e\uba74 \ud45c\uc2dc\ub85c \ud2b9\uc218 \uc18c\ud658\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Trap", "property": "Normal", "series": ["Draco"], "images": [{"index": 1, "image": "DraconicPeaceBomber-RDKP23-JP-SR.png"}], "sets": {"ja": [{"set_number": "RD/KP23-JP062", "set_name": "Gias Charge of the Nova", "rarities": ["Super Rare"]}], "ko": [{"set_number": "RD/KP23-KR062", "set_name": "Gias Charge of the Nova", "rarities": ["Super Rare"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1157301}