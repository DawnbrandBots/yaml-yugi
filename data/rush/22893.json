{"konami_id": 22893, "name": {"en": "Lovely Clean", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30e9\u30f4\u30fb\u30af\u30ea\u30fc\u30f3", "ja_romaji": "Ravu Kur\u012bn", "ko": "\ub77c\ube0c \ud074\ub9b0", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "When your opponent Normal or Special Summons a monster.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u76f8\u624b\u304c\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\u53ec\u559a\u30fb\u7279\u6b8a\u53ec\u559a\u3057\u305f\u6642\u306b\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc0c1\ub300\uac00 \ubaac\uc2a4\ud130\ub97c \uc77c\ubc18 \uc18c\ud658 / \ud2b9\uc218 \uc18c\ud658\ud588\uc744 \ub54c\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Make up to 3 face-up Fairy Type monsters with 0 original ATK on your field gain 1000 ATK until the end of this turn. Then, if you have \"All Love Goddess\" face-up on your field, you can return 1 monster from your opponent's field to the owner's hand.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u5143\u3005\u306e\u653b\u6483\u529b\u304c\uff10\u306e\u8868\u5074\u8868\u793a\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u5929\u4f7f\u65cf\uff09\u3092\uff13\u4f53\u307e\u3067\u9078\u3073\u3001\u305d\u306e\u653b\u6483\u529b\u3092\u30bf\u30fc\u30f3\u7d42\u4e86\u6642\u307e\u3067\uff11\uff10\uff10\uff10\u30a2\u30c3\u30d7\u3059\u308b\u3002\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u8868\u5074\u8868\u793a\u306e\u300c\u30aa\u30fc\u30eb\u30e9\u30f4\u30fb\u30b4\u30c3\u30c7\u30b9\u300d\u304c\u3044\u308b\u5834\u5408\u3001\u3055\u3089\u306b\u76f8\u624b\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3092\u9078\u3093\u3067\u6301\u3061\u4e3b\u306e\u624b\u672d\u306b\u623b\u3059\u4e8b\u304c\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0 \ud544\ub4dc\uc758 \uc6d0\ub798 \uacf5\uaca9\ub825\uc774 0 \uc778 \uc55e\uba74 \ud45c\uc2dc \ubaac\uc2a4\ud130(\ucc9c\uc0ac\uc871)\ub97c 3\uc7a5\uae4c\uc9c0 \uace0\ub974\uace0, \uadf8 \uacf5\uaca9\ub825\uc744 \ud134 \uc885\ub8cc\uc2dc\uae4c\uc9c0 1000 \uc62c\ub9b0\ub2e4. \uc790\uc2e0 \ud544\ub4dc\uc5d0 \uc55e\uba74 \ud45c\uc2dc\uc778 \"\uc62c\ub77c\ube0c \uac00\ub514\uc2a4\"\uac00 \uc788\uc744 \uacbd\uc6b0, \ucd94\uac00\ub85c \uc0c1\ub300 \ud544\ub4dc\uc758 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \uace0\ub974\uace0 \uc8fc\uc778\uc758 \ud328\ub85c \ub418\ub3cc\ub9b4 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Trap", "property": "Normal", "series": ["Lovely"], "images": [{"index": 1, "image": "LovelyClean-RDKP24-JP-R.png"}], "sets": {"ja": [{"set_number": "RD/KP24-JP063", "set_name": "Overforce of the Abyss", "rarities": ["Rare", "Secret Rare"]}], "ko": [{"set_number": "RD/KP24-KR063", "set_name": "Overforce of the Abyss", "rarities": ["Rare", "Secret Rare"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1171424}