{"konami_id": 22641, "name": {"en": "Fiarma the Ally Spark", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "<ruby>\u8fd1<rt>\u304d\u3093</rt></ruby><ruby>\u71d0<rt>\u308a\u3093</rt></ruby>\u306e\u30d5\u30a3\u30a2\u30fc\u30de", "ja_romaji": "Kinrin no Fi\u0101ma", "ko": "\uadfc\ub9b0\uc758 \ud53c\uc544\ub9c8", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "During the turn you Normal Summoned this card, send the top card of your Deck to the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u3092\u53ec\u559a\u3057\u305f\u30bf\u30fc\u30f3\u306b\u3001\u30c7\u30c3\u30ad\u306e\u4e00\u756a\u4e0a\u306e\u30ab\u30fc\u30c9\u3092\u5893\u5730\u3078\u9001\u3063\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc774 \uce74\ub4dc\ub97c \uc77c\ubc18 \uc18c\ud658\ud55c \ud134\uc5d0, \ub371 \ub9e8 \uc704\uc758 \uce74\ub4dc\ub97c \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Increase this card's Level by 3 until the end of this turn. Then, you can add 1 \"Sparkhearts Girl\" or 1 \"I'm Having Trouble with My Fields Being Destroyed!\" from your Graveyard to your hand. This turn, you can only attack with FIRE Attribute Spellcaster Type monsters.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u306e\u30ec\u30d9\u30eb\u306f\u30bf\u30fc\u30f3\u7d42\u4e86\u6642\u307e\u3067\uff13\u4e0a\u304c\u308b\u3002\u305d\u306e\u5f8c\u3001\u81ea\u5206\u306e\u5893\u5730\u306e\u300c\u30b9\u30d1\u30fc\u30af\u30cf\u30fc\u30c4\u30fb\u30ac\u30fc\u30eb\u300d\uff11\u4f53\u307e\u305f\u306f\u300c\u7551\u304c\u8352\u3089\u3055\u308c\u3066\u56f0\u3063\u3066\u307e\u3059\uff01\u300d\uff11\u679a\u3092\u9078\u3093\u3067\u624b\u672d\u306b\u52a0\u3048\u308b\u4e8b\u304c\u3067\u304d\u308b\u3002\u3053\u306e\u30bf\u30fc\u30f3\u3001\u81ea\u5206\u306f\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u708e\u5c5e\u6027\uff0f\u9b54\u6cd5\u4f7f\u3044\u65cf\uff09\u3067\u3057\u304b\u653b\u6483\u3067\u304d\u306a\u3044\u3002", "ko": "\uc774 \uce74\ub4dc\uc758 \ub808\ubca8\uc740 \ud134 \uc885\ub8cc\uc2dc\uae4c\uc9c0 3 \uc62c\ub77c\uac04\ub2e4. \uadf8 \ud6c4, \uc790\uc2e0 \ubb18\uc9c0\uc758 \"\uc2a4\ud30c\ud06c\ud558\uce20 \uac78\" 1\uc7a5 \ub610\ub294 \"\ubc2d\uc774 \uc5c9\ub9dd\uc774\ub77c \uace4\ub780\ud574\uc694!\" 1\uc7a5\uc744 \uace0\ub974\uace0 \ud328\uc5d0 \ub123\uc744 \uc218 \uc788\ub2e4. \uc774 \ud134\uc5d0, \uc790\uc2e0\uc740 \ubaac\uc2a4\ud130(\ud654\uc5fc \uc18d\uc131 / \ub9c8\ubc95\uc0ac\uc871)\ub85c\ubc16\uc5d0 \uacf5\uaca9\ud560 \uc218 \uc5c6\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Spellcaster / Effect", "attribute": "FIRE", "level": 3, "atk": 800, "def": 1200, "series": ["Sparkhearts"], "images": [{"index": 1, "image": "FiarmatheAllySpark-RDAP02-JP-SR.png"}], "sets": {"ja": [{"set_number": "RD/AP02-JP025", "set_name": "Advance Pack: Revenge Hearts", "rarities": ["Super Rare", "Secret Rare"]}], "ko": [{"set_number": "RD/AP02-KR025", "set_name": "Advance Pack: Revenge Hearts", "rarities": ["Super Rare", "Secret Rare"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1163694}