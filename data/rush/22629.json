{"konami_id": 22629, "name": {"en": "Skullrise Violent", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30b9\u30ab\u30eb\u30e9\u30a4\u30ba\u30fb\u30f4\u30a1\u30a4\u30aa\u30ec\u30f3\u30c8", "ja_romaji": "Sukaruraizu Vaiorento", "ko": "\uc2a4\uceec\ub77c\uc774\uc988 \ubc14\uc774\uc62c\ub7f0\ud2b8", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "None", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u306a\u3057", "ko": "\uc5c6\uc74c", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Ritual Summon \"Souffraruda the Defiant Soulclad Scripture\" by sending face-up Zombie Type monsters from your field to the Graveyard whose total Levels equal 3 or more as material (you cannot use more monsters than necessary as material). Then, if you sent a monster whose original name is \"Souffraes the Defiant Soul\" to the Graveyard by this effect, you can draw 1 card.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30ec\u30d9\u30eb\u306e\u5408\u8a08\u304c\uff13\u4ee5\u4e0a\u306b\u306a\u308b\u3088\u3046\u306b\u3001\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u8868\u5074\u8868\u793a\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30a2\u30f3\u30c7\u30c3\u30c8\u65cf\uff09\u3092\u7d20\u6750\u3068\u3057\u3066\u5893\u5730\u3078\u9001\u308a\u3001\u300c\u53db\u9aa8\u88c5\u5178\u30b9\u30d5\u30ec\u30eb\u30fc\u30c0\u300d\u3092\u30ea\u30c1\u30e5\u30a2\u30eb\u53ec\u559a\u3059\u308b\uff08\u4f59\u5206\u306b\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\u7d20\u6750\u306b\u3067\u304d\u306a\u3044\uff09\u3002\u3053\u306e\u52b9\u679c\u3067\u5143\u3005\u306e\u30ab\u30fc\u30c9\u540d\u304c\u300c\u53db\u9aa8\u306e\u30b9\u30d5\u30ec\u30fc\u30b9\u300d\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\u5893\u5730\u3078\u9001\u3063\u305f\u5834\u5408\u3001\u3055\u3089\u306b\u81ea\u5206\u306f\uff11\u679a\u30c9\u30ed\u30fc\u3067\u304d\u308b\u3002", "ko": "\ub808\ubca8\uc758 \ud569\uacc4\uac00 3 \uc774\uc0c1\uc774 \ub418\ub3c4\ub85d, \uc790\uc2e0 \ud544\ub4dc\uc758 \uc55e\uba74 \ud45c\uc2dc \ubaac\uc2a4\ud130(\uc5b8\ub370\ub4dc\uc871)\ub97c \uc18c\uc7ac\ub85c\uc11c \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uace0, \"\ubc18\uace8\uc7a5\uc804 \uc2a4\ud50c\ub808\ub8e8\ub354\"\ub97c \ub9ac\ucd94\uc5bc \uc18c\ud658\ud55c\ub2e4(\uc5ec\ubd84\uc758 \ubaac\uc2a4\ud130\ub97c \uc18c\uc7ac\ub85c \ud560 \uc218 \uc5c6\ub2e4). \uc774 \ud6a8\uacfc\ub85c \uc6d0\ub798\uc758 \uce74\ub4dc\uba85\uc774 \"\ubc18\uace8\uc758 \uc2a4\ud50c\ub808\uc774\uc2a4\"\uc778 \ubaac\uc2a4\ud130\ub97c \ubb18\uc9c0\ub85c \ubcf4\ub0c8\uc744 \uacbd\uc6b0, \ucd94\uac00\ub85c \uc790\uc2e0\uc740 1\uc7a5 \ub4dc\ub85c\uc6b0\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Spell", "property": "Ritual", "series": ["Defiant Soul"], "images": [{"index": 1, "image": "SkullriseViolent-RDAP02-JP-SR.png"}], "sets": {"ja": [{"set_number": "RD/AP02-JP012", "set_name": "Advance Pack: Revenge Hearts", "rarities": ["Super Rare", "Secret Rare"]}], "ko": [{"set_number": "RD/AP02-KR012", "set_name": "Advance Pack: Revenge Hearts", "rarities": ["Super Rare", "Secret Rare"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1161381}