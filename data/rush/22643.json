{"konami_id": 22643, "name": {"en": "Sparkhearts Familiar", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30b9\u30d1\u30fc\u30af\u30cf\u30fc\u30c4\u30fb\u30d5\u30a1\u30df\u30ea\u30a2", "ja_romaji": "Sup\u0101kuh\u0101tsu Famiria", "ko": "\uc2a4\ud30c\ud06c\ud558\uce20 \ud328\ubc00\ub9ac\uc5b4", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "You have 10 or more cards in your Deck during the turn you Normal Summoned this card.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u3092\u53ec\u559a\u3057\u305f\u30bf\u30fc\u30f3\u306b\u3001\u81ea\u5206\u306e\u30c7\u30c3\u30ad\u306e\u30ab\u30fc\u30c9\u304c\uff11\uff10\u679a\u4ee5\u4e0a\u306e\u5834\u5408\u306b\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc774 \uce74\ub4dc\ub97c \uc77c\ubc18 \uc18c\ud658\ud55c \ud134\uc5d0, \uc790\uc2e0 \ub371\uc758 \uce74\ub4dc\uac00 10\uc7a5 \uc774\uc0c1\uc77c \uacbd\uc6b0\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Send 2 other cards from your hand and/or field to the Graveyard. Then, if you have \"Sparkhearts Girl\", \"Sparks\", or \"Curtain of Sparks\" in your Graveyard, you can draw 2 cards. This turn, you can only attack with FIRE Attribute Spellcaster Type monsters.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u4ee5\u5916\u306e\u81ea\u5206\u306e\u624b\u672d\u30fb\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u30ab\u30fc\u30c9\uff12\u679a\u3092\u9078\u3093\u3067\u5893\u5730\u3078\u9001\u308b\u3002\u305d\u306e\u5f8c\u3001\u81ea\u5206\u306e\u5893\u5730\u306b\u300c\u30b9\u30d1\u30fc\u30af\u30cf\u30fc\u30c4\u30fb\u30ac\u30fc\u30eb\u300d\u300c\u706b\u306e\u7c89\u300d\u300c\u706b\u306e\u7c89\u306e\u30ab\u30fc\u30c6\u30f3\u300d\u306e\u3044\u305a\u308c\u304b\u304c\u3042\u308b\u5834\u5408\u3001\u81ea\u5206\u306f\uff12\u679a\u30c9\u30ed\u30fc\u3067\u304d\u308b\u3002\u3053\u306e\u30bf\u30fc\u30f3\u3001\u81ea\u5206\u306f\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u708e\u5c5e\u6027\uff0f\u9b54\u6cd5\u4f7f\u3044\u65cf\uff09\u3067\u3057\u304b\u653b\u6483\u3067\u304d\u306a\u3044\u3002", "ko": "\uc774 \uce74\ub4dc \uc774\uc678\uc758 \uc790\uc2e0\uc758 \ud328 / \ud544\ub4dc\uc758 \uce74\ub4dc 2\uc7a5\uc744 \uace0\ub974\uace0 \ubb18\uc9c0\ub85c \ubcf4\ub0b8\ub2e4. \uadf8 \ud6c4, \uc790\uc2e0 \ubb18\uc9c0\uc5d0 \"\uc2a4\ud30c\ud06c\ud558\uce20 \uac78\" \"\uc2a4\ud30c\ud06c\" \"\uc2a4\ud30c\ud06c \ucee4\ud2bc\" \uc911 \uc5b4\ub290 \uac83\uc774 \uc788\uc744 \uacbd\uc6b0, \uc790\uc2e0\uc740 2\uc7a5 \ub4dc\ub85c\uc6b0\ud560 \uc218 \uc788\ub2e4. \uc774 \ud134\uc5d0, \uc790\uc2e0\uc740 \ubaac\uc2a4\ud130(\ud654\uc5fc \uc18d\uc131 / \ub9c8\ubc95\uc0ac\uc871)\ub85c\ubc16\uc5d0 \uacf5\uaca9\ud560 \uc218 \uc5c6\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Spellcaster / Effect", "attribute": "FIRE", "level": 3, "atk": 600, "def": 1200, "series": ["Sparkhearts"], "images": [{"index": 1, "image": "SparkheartsFamiliar-RDAP02-JP-C.png"}], "sets": {"ja": [{"set_number": "RD/AP02-JP027", "set_name": "Advance Pack: Revenge Hearts", "rarities": ["Common"]}, {"set_number": "RD/B261-JP003", "set_name": "Battle Bonus Pack 2026 Vol.1", "rarities": ["Super Parallel Rare"]}], "ko": [{"set_number": "RD/AP02-KR027", "set_name": "Advance Pack: Revenge Hearts", "rarities": ["Common"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1166809}