{"konami_id": 22407, "name": {"en": "The Draco", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30b6\u2606\u30c9\u30e9\u30b3", "ja_romaji": "Za\u2606Dorako", "ko": "\ub354\u2606\ub4dc\ub77c\ucf54", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "During the turn you Normal Summoned this card, send 1 card from your hand to the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u3092\u53ec\u559a\u3057\u305f\u30bf\u30fc\u30f3\u306b\u3001\u624b\u672d\uff11\u679a\u3092\u5893\u5730\u3078\u9001\u3063\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": null, "zh-TW": null, "zh-CN": null}, "effect": {"en": "This turn, this card's name becomes \"The Dragon\". Then, if the only monsters in your Graveyard are High Dragon and/or Dragon Type monsters, you can Fusion Summon a High Dragon Type monster with 2000 DEF by shuffling monsters from your hand or field into the owner's Deck as material.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u306e\u30ab\u30fc\u30c9\u540d\u306f\u3053\u306e\u30bf\u30fc\u30f3\u3001\u300c\u30b6\u2606\u30c9\u30e9\u30b4\u30f3\u300d\u306b\u306a\u308b\u3002\u81ea\u5206\u306e\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u304c\u30cf\u30a4\u30c9\u30e9\u30b4\u30f3\u65cf\u30fb\u30c9\u30e9\u30b4\u30f3\u65cf\u306e\u307f\u306e\u5834\u5408\u3001\u3055\u3089\u306b\u81ea\u5206\u306e\u624b\u672d\u30fb\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\u7d20\u6750\u3068\u3057\u3066\u6301\u3061\u4e3b\u306e\u30c7\u30c3\u30ad\u306b\u623b\u3057\u3066\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30cf\u30a4\u30c9\u30e9\u30b4\u30f3\u65cf\uff0f\u5b88\u5099\u529b\uff12\uff10\uff10\uff10\uff09\u3092\u30d5\u30e5\u30fc\u30b8\u30e7\u30f3\u53ec\u559a\u3067\u304d\u308b\u3002", "ko": "\u3010\uc870\uac74\u3011\uc774 \uce74\ub4dc\ub97c \uc77c\ubc18 \uc18c\ud658\ud55c \ud134\uc5d0, \ud328 1\uc7a5\uc744 \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.\n\u3010\ud6a8\uacfc\u3011\uc774 \uce74\ub4dc\uc758 \uce74\ub4dc\uba85\uc740 \uc774 \ud134\uc5d0, \"\ub354\u2606\ub4dc\ub798\uace4\"\uc774 \ub41c\ub2e4. \uc790\uc2e0 \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130\uac00 \ud558\uc774\ub4dc\ub798\uace4\uc871 / \ub4dc\ub798\uace4\uc871\ubfd0\uc77c \uacbd\uc6b0, \ucd94\uac00\ub85c \uc790\uc2e0\uc758 \ud328 / \ud544\ub4dc\uc758 \ubaac\uc2a4\ud130\ub97c \uc18c\uc7ac\ub85c\uc11c \uc8fc\uc778\uc758 \ub371\uc73c\ub85c \ub418\ub3cc\ub9ac\uace0 \ubaac\uc2a4\ud130(\ud558\uc774\ub4dc\ub798\uace4\uc871 / \uc218\ube44\ub825 2000)\ub97c \ud4e8\uc804 \uc18c\ud658\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Dragon / Effect", "attribute": "FIRE", "level": 1, "atk": 0, "def": 1400, "series": ["Draco", "The"], "images": [{"index": 1, "image": "TheDraco-RDKP23-JP-R.png"}], "sets": {"ja": [{"set_number": "RD/KP23-JP002", "set_name": "Gias Charge of the Nova", "rarities": ["Rare", "Secret Rare"]}], "ko": [{"set_number": "RD/KP23-KR002", "set_name": "Gias Charge of the Nova", "rarities": ["Rare", "Secret Rare"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1145882}