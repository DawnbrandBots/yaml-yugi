{"konami_id": 22830, "name": {"en": "Beast King Barbaros", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "<ruby>\u795e<rt>\u3057\u3093</rt></ruby><ruby>\u7363<rt>\u3058\u3085\u3046</rt></ruby><ruby>\u738b<rt>\u304a\u3046</rt></ruby>\u30d0\u30eb\u30d0\u30ed\u30b9", "ja_romaji": null, "ko": "\uc2e0\uc218\uc655 \ubc14\ub974\ubc14\ub85c\uc2a4", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "summoning_condition": {"en": "You can Normal Summon this card in Attack Position without Tributing or by Tributing 3 face-up EARTH Attribute monsters. If Summoned without Tributing, its original ATK becomes 1900.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u306f\u30ea\u30ea\u30fc\u30b9\u306a\u3057\u3001\u307e\u305f\u306f\u8868\u5074\u8868\u793a\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u5730\u5c5e\u6027\uff09\uff13\u4f53\u3092\u30ea\u30ea\u30fc\u30b9\u3057\u3066\u653b\u6483\u8868\u793a\u3067\u53ec\u559a\u3067\u304d\u308b\u3002\u30ea\u30ea\u30fc\u30b9\u306a\u3057\u306e\u5834\u5408\u3001\u3053\u306e\u30ab\u30fc\u30c9\u306e\u5143\u3005\u306e\u653b\u6483\u529b\u306f\uff11\uff19\uff10\uff10\u306b\u306a\u308b\u3002", "ko": "\uc774 \uce74\ub4dc\ub294 \ub9b4\ub9ac\uc2a4 \uc5c6\uc774, \ub610\ub294 \uc55e\uba74 \ud45c\uc2dc \ubaac\uc2a4\ud130(\ub545 \uc18d\uc131) 3\uc7a5\uc744 \ub9b4\ub9ac\uc2a4\ud558\uace0 \uacf5\uaca9 \ud45c\uc2dc\ub85c \uc77c\ubc18 \uc18c\ud658\ud560 \uc218 \uc788\ub2e4. \ub9b4\ub9ac\uc2a4 \uc5c6\uc774 \ud560 \uacbd\uc6b0, \uc774 \uce74\ub4dc\uc758 \uc6d0\ub798 \uacf5\uaca9\ub825\uc740 1900 \uc774 \ub41c\ub2e4.", "zh-TW": null, "zh-CN": null}, "requirement": {"en": "During the turn you Normal Summoned this card by Tributing 3 monsters the above way.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u4e0a\u8a18\u306e\u65b9\u6cd5\u3067\u30e2\u30f3\u30b9\u30bf\u30fc\uff13\u4f53\u3092\u30ea\u30ea\u30fc\u30b9\u3057\u3066\u3053\u306e\u30ab\u30fc\u30c9\u3092\u53ec\u559a\u3057\u305f\u30bf\u30f