{"konami_id": 22858, "name": {"en": "Mad Rare Amelo", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30de\u30c3\u30c9\u30ec\u30a2\u30fb\u30a2\u30e1\u30ed", "ja_romaji": "Maddorea Amero", "ko": "\ub9e4\ub4dc\ub808\uc5b4 \uc544\uba54\ub85c", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "During the turn you Normal Summoned this card, shuffle 3 monsters from your Graveyard into the Deck.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u3092\u53ec\u559a\u3057\u305f\u30bf\u30fc\u30f3\u306b\u3001\u81ea\u5206\u306e\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff13\u4f53\u3092\u30c7\u30c3\u30ad\u306b\u623b\u3057\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc774 \uce74\ub4dc\ub97c \uc77c\ubc18 \uc18c\ud658\ud55c \ud134\uc5d0, \uc790\uc2e0 \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130 3\uc7a5\uc744 \ub371\uc73c\ub85c \ub418\ub3cc\ub9ac\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Destroy 1 Attack Position Level 3-8 Effect Monster on your opponent's field. Then, if you destroyed a monster whose original Level is 6 by this effect, you can inflict 600 damage to your opponent. This turn, you cannot attack with Level 6 or lower monsters.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u76f8\u624b\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u653b\u6483\u8868\u793a\u306e\u52b9\u679c\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30ec\u30d9\u30eb\uff13\uff5e\uff18\uff09\uff11\u4f53\u3092\u9078\u3093\u3067\u7834\u58ca\u3059\u308b\u3002\u3053\u306e\u52b9\u679c\u3067\u5143\u3005\u306e\u30ec\u30d9\u30eb\u304c\uff16\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\u7834\u58ca\u3057\u305f\u5834\u5408\u3001\u3055\u3089\u306b\u76f8\u624b\u306b\uff16\uff10\uff10\u30c0\u30e1\u30fc\u30b8\u3092\u4e0e\u3048\u308b\u4e8b\u304c\u3067\u304d\u308b\u3002\u3053\u306e\u30bf\u30fc\u30f3\u3001\u81ea\u5206\u306f\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30ec\u30d9\u30eb\uff16\u4ee5\u4e0b\uff09\u3067\u653b\u6483\u3067\u304d\u306a\u3044\u3002", "ko": "\uc0c1\ub300 \ud544\ub4dc\uc758 \uacf5\uaca9 \ud45c\uc2dc\uc778 \ud6a8\uacfc \ubaac\uc2a4\ud130(\ub808\ubca8 3~8) 1\uc7a5\uc744 \uace0\ub974\uace0 \ud30c\uad34\ud55c\ub2e4. \uc774 \ud6a8\uacfc\ub85c \uc6d0\ub798\uc758 \ub808\ubca8\uc774 6 \uc778 \ubaac\uc2a4\ud130\ub97c \ud30c\uad34\ud588\uc744 \uacbd\uc6b0, \ucd94\uac00\ub85c \uc0c1\ub300\uc5d0\uac8c 600 \ub370\ubbf8\uc9c0\ub97c \uc904 \uc218 \uc788\ub2e4. \uc774 \ud134\uc5d0, \uc790\uc2e0\uc740 \ubaac\uc2a4\ud130(\ub808\ubca8 6 \uc774\ud558)\ub85c \uacf5\uaca9\ud560 \uc218 \uc5c6\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Reptile / Effect", "attribute": "DARK", "level": 4, "atk": 1300, "def": 1100, "images": [{"index": 1, "image": "MadRareAmelo-RDKP24-JP-UR.png", "illustration": "MadRareAmelo-OW.png"}, {"index": 2, "image": "MadRareAmelo-RDKP24-JP-ORR-AA.png"}], "sets": {"ja": [{"set_number": "RD/KP24-JP028", "set_name": "Overforce of the Abyss", "rarities": ["Ultra Rare", "Secret Rare", "Over Rush Rare"]}], "ko": [{"set_number": "RD/KP24-KR028", "set_name": "Overforce of the Abyss", "rarities": ["Ultra Rare", "Secret Rare", "Over Rush Rare"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1167081}