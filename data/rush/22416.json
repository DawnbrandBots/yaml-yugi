{"konami_id": 22416, "name": {"en": "Benevolent Dragon", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30c7\u30a3\u30b9\u30b8\u30e3\u30fc\u30ad\u30fc\u30fb\u30c9\u30e9\u30b4\u30f3", "ja_romaji": "Disuj\u0101k\u012b Doragon", "ko": "\ub514\uc2a4\uc800\ud0a4 \ub4dc\ub798\uace4", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "Send 1 other card from your field to the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u4ee5\u5916\u306e\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u30ab\u30fc\u30c9\uff11\u679a\u3092\u5893\u5730\u3078\u9001\u3063\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc774 \uce74\ub4dc \uc774\uc678\uc758 \uc790\uc2e0 \ud544\ub4dc\uc758 \uce74\ub4dc 1\uc7a5\uc744 \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Return this card from your field to the owner's hand. Then, you can Special Summon 1 Level 7 Dragon Type monster from your Graveyard face-up to your field. This turn, you cannot activate the effect of \"Benevolent Dragon\".", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u3053\u306e\u30ab\u30fc\u30c9\u3092\u6301\u3061\u4e3b\u306e\u624b\u672d\u306b\u623b\u3059\u3002\u305d\u306e\u5f8c\u3001\u81ea\u5206\u306e\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30ec\u30d9\u30eb\uff17\uff0f\u30c9\u30e9\u30b4\u30f3\u65cf\uff09\uff11\u4f53\u3092\u9078\u3093\u3067\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u8868\u5074\u8868\u793a\u3067\u7279\u6b8a\u53ec\u559a\u3067\u304d\u308b\u3002\u3053\u306e\u30bf\u30fc\u30f3\u3001\u81ea\u5206\u306f\u300c\u30c7\u30a3\u30b9\u30b8\u30e3\u30fc\u30ad\u30fc\u30fb\u30c9\u30e9\u30b4\u30f3\u300d\u306e\u52b9\u679c\u3092\u767a\u52d5\u3067\u304d\u306a\u3044\u3002", "ko": "\uc790\uc2e0 \ud544\ub4dc\uc758 \uc774 \uce74\ub4dc\ub97c \uc8fc\uc778\uc758 \ud328\ub85c \ub418\ub3cc\ub9b0\ub2e4. \uadf8 \ud6c4, \uc790\uc2e0 \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130(\ub808\ubca8 7 / \ub4dc\ub798\uace4\uc871) 1\uc7a5\uc744 \uace0\ub974\uace0 \uc790\uc2e0 \ud544\ub4dc\uc5d0 \uc55e\uba74 \ud45c\uc2dc\ub85c \ud2b9\uc218 \uc18c\ud658\ud560 \uc218 \uc788\ub2e4. \uc774 \ud134\uc5d0, \uc790\uc2e0\uc740 \"\ub514\uc2a4\uc800\ud0a4 \ub4dc\ub798\uace4\"\uc758 \ud6a8\uacfc\ub97c \ubc1c\ub3d9\ud560 \uc218 \uc5c6\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Dragon / Effect", "attribute": "LIGHT", "level": 7, "atk": 1800, "def": 1800, "images": [{"index": 1, "image": "BenevolentDragon-RDKP23-JP-C.png"}], "sets": {"ja": [{"set_number": "RD/KP23-JP011", "set_name": "Gias Charge of the Nova", "rarities": ["Common"]}], "ko": [{"set_number": "RD/KP23-KR011", "set_name": "Gias Charge of the Nova", "rarities": ["Common"]}]}, "is_translation_unofficial": {"text": {"en": true}}, "yugipedia_page_id": 1159678}