{"konami_id": 22343, "name": {"en": "Rescue Rabbit", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30ec\u30b9\u30ad\u30e5\u30fc\u30e9\u30d3\u30c3\u30c8", "ja_romaji": null, "ko": "\ub808\uc2a4\ud050 \ub798\ube57", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "Place this face-up card from your field on the bottom of the owner's Deck.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u8868\u5074\u8868\u793a\u306e\u3053\u306e\u30ab\u30fc\u30c9\u3092\u6301\u3061\u4e3b\u306e\u30c7\u30c3\u30ad\u306e\u4e0b\u306b\u623b\u3057\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0 \ud544\ub4dc\uc758 \uc55e\uba74 \ud45c\uc2dc\uc778 \uc774 \uce74\ub4dc\ub97c \uc8fc\uc778\uc758 \ub371 \uc544\ub798\ub85c \ub418\ub3cc\ub9ac\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Special Summon 2 Level 4 or lower Normal Monsters with the same Type from your Graveyard face-up to your field. Destroy the monsters Special Summoned by this effect during the End Phase of this turn. This turn, you cannot activate the effect of \"Rescue Rabbit\".", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306e\u5893\u5730\u306e\u540c\u3058\u7a2e\u65cf\u306e\u901a\u5e38\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30ec\u30d9\u30eb\uff14\u4ee5\u4e0b\uff09\uff12\u4f53\u3092\u9078\u3073\u3001\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u8868\u5074\u8868\u793a\u3067\u7279\u6b8a\u53ec\u559a\u3059\u308b\u3002\u3053\u306e\u52b9\u679c\u3067\u7279\u6b8a\u53ec\u559a\u3057\u305f\u30e2\u30f3\u30b9\u30bf\u30fc\u306f\u3053\u306e\u30bf\u30fc\u30f3\u306e\u30a8\u30f3\u30c9\u30d5\u30a7\u30a4\u30ba\u306b\u7834\u58ca\u3055\u308c\u308b\u3002\u3053\u306e\u30bf\u30fc\u30f3\u3001\u81ea\u5206\u306f\u300c\u30ec\u30b9\u30ad\u30e5\u30fc\u30e9\u30d3\u30c3\u30c8\u300d\u306e\u52b9\u679c\u3092\u767a\u52d5\u3067\u304d\u306a\u3044\u3002", "ko": "\uc790\uc2e0 \ubb18\uc9c0\uc758 \uac19\uc740 \uc885\uc871\uc758 \uc77c\ubc18 \ubaac\uc2a4\ud130(\ub808\ubca8 4 \uc774\ud558) 2\uc7a5\uc744 \uace0\ub974\uace0, \uc790\uc2e0 \ud544\ub4dc\uc5d0 \uc55e\uba74 \ud45c\uc2dc\ub85c \ud2b9\uc218 \uc18c\ud658\ud55c\ub2e4. \uc774 \ud6a8\uacfc\ub85c \ud2b9\uc218 \uc18c\ud658\ud55c \ubaac\uc2a4\ud130\ub294 \uc774 \ud134\uc758 \uc5d4\ub4dc \ud398\uc774\uc988\uc5d0 \ud30c\uad34\ub41c\ub2e4. \uc774 \ud134\uc5d0, \uc790\uc2e0\uc740 \"\ub808\uc2a4\ud050 \ub798\ube57\"\uc758 \ud6a8\uacfc\ub97c \ubc1c\ub3d9\ud560 \uc218 \uc5c6\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Beast / Effect", "attribute": "EARTH", "level": 4, "atk": 300, "def": 100, "images": [{"index": 1, "image": "RescueRabbit-RDSJMP-JP-NPR.png"}], "sets": {"ja": [{"set_number": "RD/SJMP-JP057", "set_name": "Saiky\u014d Jump December 2025 promotional card", "rarities": ["Normal Parallel Rare"]}], "ko": [{"set_number": "RD/KP23-KRS01", "set_name": "Gias Charge of the Nova", "rarities": ["Super Rare"]}]}, "is_translation_unofficial": {"text": {"en": true}}, "yugipedia_page_id": 1151135}