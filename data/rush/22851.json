{"konami_id": 22851, "name": {"en": "Grace Princess Emaki", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3044\u3068\u3092\u304b\u3057\u3048\u307e\u304d\u3072\u3081", "ja_romaji": "Itowokashi Emakihime", "ko": "\uc559\uac31\ud68c\uad8c\ud76c", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "Send 1 card from your hand to the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u624b\u672d\uff11\u679a\u3092\u5893\u5730\u3078\u9001\u3063\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\ud328 1\uc7a5\uc744 \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Send the top 3 cards of your Deck to the Graveyard. Then, you can add 1 Aqua Type Normal Monster or 1 Level 4 LIGHT Attribute Aqua Type monster from your Graveyard to your hand. If you added \"Grace Princess Kana\" by this effect, you can Set 1 Ritual Spell Card from your Graveyard to your Spell & Trap Zone.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306e\u30c7\u30c3\u30ad\u306e\u4e0a\u304b\u3089\u30ab\u30fc\u30c9\uff13\u679a\u3092\u5893\u5730\u3078\u9001\u308b\u3002\u305d\u306e\u5f8c\u3001\u81ea\u5206\u306e\u5893\u5730\u306e\u901a\u5e38\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u6c34\u65cf\uff09\u307e\u305f\u306f\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30ec\u30d9\u30eb\uff14\uff0f\u5149\u5c5e\u6027\uff0f\u6c34\u65cf\uff09\uff11\u4f53\u3092\u9078\u3093\u3067\u624b\u672d\u306b\u52a0\u3048\u308b\u4e8b\u304c\u3067\u304d\u308b\u3002\u3053\u306e\u52b9\u679c\u3067\u300c\u3044\u3068\u3092\u304b\u3057\u304b\u306a\u3072\u3081\u300d\u3092\u9078\u3093\u3060\u5834\u5408\u3001\u3055\u3089\u306b\u81ea\u5206\u306e\u5893\u5730\u306e\u30ea\u30c1\u30e5\u30a2\u30eb\u9b54\u6cd5\u30ab\u30fc\u30c9\uff11\u679a\u3092\u9078\u3093\u3067\u81ea\u5206\u306e\u9b54\u6cd5\uff06\u7f60\u30be\u30fc\u30f3\u306b\u30bb\u30c3\u30c8\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0\uc758 \ub371 \uc704\uc5d0\uc11c \uce74\ub4dc 3\uc7a5\uc744 \ubb18\uc9c0\ub85c \ubcf4\ub0b8\ub2e4. \uadf8 \ud6c4, \uc790\uc2e0 \ubb18\uc9c0\uc758 \uc77c\ubc18 \ubaac\uc2a4\ud130(\ubb3c\uc871) \ub610\ub294 \ubaac\uc2a4\ud130(\ub808\ubca8 4 / \ube5b \uc18d\uc131 / \ubb3c\uc871) 1\uc7a5\uc744 \uace0\ub974\uace0 \ud328\uc5d0 \ub123\uc744 \uc218 \uc788\ub2e4. \uc774 \ud6a8\uacfc\ub85c \"\uc559\uac31\uacf5\uc8fc\"\ub97c \uace0\ub978 \uacbd\uc6b0, \ucd94\uac00\ub85c \uc790\uc2e0 \ubb18\uc9c0\uc758 \ub9ac\ucd94\uc5bc \ub9c8\ubc95 \uce74\ub4dc 1\uc7a5\uc744 \uace0\ub974\uace0 \uc790\uc2e0\uc758 \ub9c8\ubc95 & \ud568\uc815 \uc874\uc5d0 \uc138\ud2b8\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Aqua / Effect", "attribute": "LIGHT", "level": 5, "atk": 1700, "def": 1400, "series": ["Grace Princess"], "images": [{"index": 1, "image": "GracePrincessEmaki-RDKP24-JP-SR.png"}], "sets": {"ja": [{"set_number": "RD/KP24-JP021", "set_name": "Overforce of the Abyss", "rarities": ["Super Rare", "Secret Rare"]}], "ko": [{"set_number": "RD/KP24-KR021", "set_name": "Overforce of the Abyss", "rarities": ["Super Rare", "Secret Rare"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1166886}