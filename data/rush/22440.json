{"konami_id": 22440, "name": {"en": "Intensive Magician", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "<ruby>\u96c6<rt>\u3057\u3085\u3046</rt></ruby><ruby>\u7d04<rt>\u3084\u304f</rt></ruby>\u306e<ruby>\u9b54<rt>\u307e</rt></ruby><ruby>\u5c0e<rt>\u3069\u3046</rt></ruby><ruby>\u5e2b<rt>\u3057</rt></ruby>", "ja_romaji": "Sh\u016byaku no Mad\u014dshi", "ko": "\uc9d1\uc57d\uc758 \ub9c8\ub3c4\uc0ac", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "During the turn you Normal Summoned this card, send the top 2 cards of your Deck to the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u3092\u53ec\u559a\u3057\u305f\u30bf\u30fc\u30f3\u306b\u3001\u30c7\u30c3\u30ad\u306e\u4e0a\u304b\u3089\u30ab\u30fc\u30c9\uff12\u679a\u3092\u5893\u5730\u3078\u9001\u3063\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc774 \uce74\ub4dc\ub97c \uc77c\ubc18 \uc18c\ud658\ud55c \ud134\uc5d0, \ub371 \uc704\uc5d0\uc11c \uce74\ub4dc 2\uc7a5\uc744 \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "This card gains ATK equal to [the number of Spell/Trap Cards on your field] x 500 until the end of this turn. Then, if you have \"Mage Power\" in your Graveyard, this card gains an additional 1000 ATK until the end of this turn.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u306e\u653b\u6483\u529b\u306f\u30bf\u30fc\u30f3\u7d42\u4e86\u6642\u307e\u3067\u3001\uff3b\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u9b54\u6cd5\u30fb\u7f60\u30ab\u30fc\u30c9\u306e\u6570\uff3d\u00d7\uff15\uff10\uff10\u30a2\u30c3\u30d7\u3059\u308b\u3002\u81ea\u5206\u306e\u5893\u5730\u306b\u300c\u9b54\u5c0e\u5e2b\u306e\u529b\u300d\u304c\u3042\u308b\u5834\u5408\u3001\u3055\u3089\u306b\u3053\u306e\u30ab\u30fc\u30c9\u306e\u653b\u6483\u529b\u306f\u30bf\u30fc\u30f3\u7d42\u4e86\u6642\u307e\u3067\uff11\uff10\uff10\uff10\u30a2\u30c3\u30d7\u3059\u308b\u3002", "ko": "\uc774 \uce74\ub4dc\uc758 \uacf5\uaca9\ub825\uc740 \ud134 \uc885\ub8cc\uc2dc\uae4c\uc9c0, [\uc790\uc2e0 \ud544\ub4dc\uc758 \ub9c8\ubc95 / \ud568\uc815 \uce74\ub4dc\uc758 \uc218] \u00d7 500 \uc62c\ub9b0\ub2e4. \uc790\uc2e0 \ubb18\uc9c0\uc5d0 \"\ub9c8\ub3c4\uc0ac\uc758 \ud798\"\uc774 \uc788\uc744 \uacbd\uc6b0, \ucd94\uac00\ub85c \uc774 \uce74\ub4dc\uc758 \uacf5\uaca9\ub825\uc740 \ud134 \uc885\ub8cc\uc2dc\uae4c\uc9c0 1000 \uc62c\ub9b0\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Spellcaster / Effect", "attribute": "EARTH", "level": 4, "atk": 1000, "def": 500, "images": [{"index": 1, "image": "IntensiveMagician-RDKP23-JP-C.png"}], "sets": {"ja": [{"set_number": "RD/KP23-JP035", "set_name": "Gias Charge of the Nova", "rarities": ["Common"]}], "ko": [{"set_number": "RD/KP23-KR035", "set_name": "Gias Charge of the Nova", "rarities": ["Common"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1158934}