{"konami_id": 22639, "name": {"en": "Sparkhearts Makma", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30b9\u30d1\u30fc\u30af\u30cf\u30fc\u30c4\u30fb\u30de\u30af\u30de", "ja_romaji": "Sup\u0101kuh\u0101tsu Makuma", "ko": "\uc2a4\ud30c\ud06c\ud558\uce20 \ub9c8\ud06c\ub9c8", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "Shuffle 2 FIRE Attribute Spellcaster Type monsters or 4 monsters from your Graveyard into the Deck.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306e\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u708e\u5c5e\u6027\uff0f\u9b54\u6cd5\u4f7f\u3044\u65cf\uff09\uff12\u4f53\u307e\u305f\u306f\u30e2\u30f3\u30b9\u30bf\u30fc\uff14\u4f53\u3092\u30c7\u30c3\u30ad\u306b\u623b\u3057\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0 \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130(\ud654\uc5fc \uc18d\uc131 / \ub9c8\ubc95\uc0ac\uc871) 2\uc7a5 \ub610\ub294 \ubaac\uc2a4\ud130 4\uc7a5\uc744 \ub371\uc73c\ub85c \ub418\ub3cc\ub9ac\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Change the battle position of up to 2 face-up monsters on your field and/or monsters on your opponent's field. Then, if you have 10 or more cards in your Deck, you can add up to 4 \"Sparkhearts Girl\", \"Sparks\", and/or \"Curtain of Sparks\" from your Graveyard to your hand.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u8868\u5074\u8868\u793a\u30e2\u30f3\u30b9\u30bf\u30fc\u307e\u305f\u306f\u76f8\u624b\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\u5408\u8a08\uff12\u4f53\u307e\u3067\u9078\u3093\u3067\u8868\u793a\u5f62\u5f0f\u3092\u5909\u66f4\u3059\u308b\u3002\u81ea\u5206\u306e\u30c7\u30c3\u30ad\u306e\u30ab\u30fc\u30c9\u304c\uff11\uff10\u679a\u4ee5\u4e0a\u306e\u5834\u5408\u3001\u3055\u3089\u306b\u81ea\u5206\u306e\u5893\u5730\u306e\u300c\u30b9\u30d1\u30fc\u30af\u30cf\u30fc\u30c4\u30fb\u30ac\u30fc\u30eb\u300d\u300c\u706b\u306e\u7c89\u300d\u300c\u706b\u306e\u7c89\u306e\u30ab\u30fc\u30c6\u30f3\u300d\u3092\u5408\u8a08\uff14\u679a\u307e\u3067\u9078\u3093\u3067\u624b\u672d\u306b\u52a0\u3048\u308b\u4e8b\u304c\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0 \ud544\ub4dc\uc758 \uc55e\uba74 \ud45c\uc2dc \ubaac\uc2a4\ud130 \ub610\ub294 \uc0c1\ub300 \ud544\ub4dc\uc758 \ubaac\uc2a4\ud130\ub97c \ud569\uacc4 2\uc7a5\uae4c\uc9c0 \uace0\ub974\uace0 \ud45c\uc2dc \ud615\uc2dd\uc744 \ubcc0\uacbd\ud55c\ub2e4. \uc790\uc2e0 \ub371\uc758 \uce74\ub4dc\uac00 10\uc7a5 \uc774\uc0c1\uc77c \uacbd\uc6b0, \ucd94\uac00\ub85c \uc790\uc2e0 \ubb18\uc9c0\uc758 \"\uc2a4\ud30c\ud06c\ud558\uce20 \uac78\" \"\uc2a4\ud30c\ud06c\" \"\uc2a4\ud30c\ud06c \ucee4\ud2bc\"\uc744 \ud569\uacc4 4\uc7a5\uae4c\uc9c0 \uace0\ub974\uace0 \ud328\uc5d0 \ub123\uc744 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Spellcaster / Effect", "attribute": "FIRE", "level": 6, "atk": 1600, "def": 1800, "series": ["Sparkhearts"], "images": [{"index": 1, "image": "SparkheartsMakma-RDAP02-JP-SR.png"}], "sets": {"ja": [{"set_number": "RD/AP02-JP023", "set_name": "Advance Pack: Revenge Hearts", "rarities": ["Super Rare", "Secret Rare"]}], "ko": [{"set_number": "RD/AP02-KR023", "set_name": "Advance Pack: Revenge Hearts", "rarities": ["Super Rare", "Secret Rare"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1159936}