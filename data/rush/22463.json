{"konami_id": 22463, "name": {"en": "War-Lion Assault", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30e9\u30a4\u30aa\u30f3\u306e<ruby>\u5f37<rt>\u304d\u3087\u3046</rt></ruby><ruby>\u8972<rt>\u3057\u3085\u3046</rt></ruby>", "ja_romaji": "Raion no Ky\u014dsh\u016b", "ko": "\ub77c\uc774\uc628\uc758 \uac15\uc2b5", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "None", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u306a\u3057", "ko": "\uc5c6\uc74c", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Ritual Summon \"Super War-Lion\" by sending face-up Beast Type monsters from your field to the Graveyard whose total Levels equal 7 or more as material (you cannot use more monsters than necessary as material). The monster Special Summoned by this effect gains 2000 ATK until the end of this turn.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30ec\u30d9\u30eb\u306e\u5408\u8a08\u304c\uff17\u4ee5\u4e0a\u306b\u306a\u308b\u3088\u3046\u306b\u3001\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u8868\u5074\u8868\u793a\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u7363\u65cf\uff09\u3092\u7d20\u6750\u3068\u3057\u3066\u5893\u5730\u3078\u9001\u308a\u3001\u300c\u30b9\u30fc\u30d1\u30fc\u30fb\u30a6\u30a9\u30fc\u30fb\u30e9\u30a4\u30aa\u30f3\u300d\u3092\u30ea\u30c1\u30e5\u30a2\u30eb\u53ec\u559a\u3059\u308b\uff08\u4f59\u5206\u306b\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\u7d20\u6750\u306b\u3067\u304d\u306a\u3044\uff09\u3002\u3053\u306e\u52b9\u679c\u3067\u7279\u6b8a\u53ec\u559a\u3057\u305f\u30e2\u30f3\u30b9\u30bf\u30fc\u306e\u653b\u6483\u529b\u306f\u30bf\u30fc\u30f3\u7d42\u4e86\u6642\u307e\u3067\uff12\uff10\uff10\uff10\u30a2\u30c3\u30d7\u3059\u308b\u3002", "ko": "\ub808\ubca8\uc758 \ud569\uacc4\uac00 7 \uc774\uc0c1\uc774 \ub418\ub3c4\ub85d, \uc790\uc2e0 \ud544\ub4dc\uc758 \uc55e\uba74 \ud45c\uc2dc \ubaac\uc2a4\ud130(\uc57c\uc218\uc871)\ub97c \uc18c\uc7ac\ub85c\uc11c \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uace0, \"\uc288\ud37c \uc6cc \ub77c\uc774\uc628\"\uc744 \ub9ac\ucd94\uc5bc \uc18c\ud658\ud55c\ub2e4(\uc5ec\ubd84\uc758 \ubaac\uc2a4\ud130\ub97c \uc18c\uc7ac\ub85c \ud560 \uc218 \uc5c6\ub2e4). \uc774 \ud6a8\uacfc\ub85c \ud2b9\uc218 \uc18c\ud658\ud55c \ubaac\uc2a4\ud130\uc758 \uacf5\uaca9\ub825\uc740 \ud134 \uc885\ub8cc\uc2dc\uae4c\uc9c0 2000 \uc62c\ub9b0\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Spell", "property": "Ritual", "series": ["War-Lion"], "images": [{"index": 1, "image": "WarLionAssault-RDKP23-JP-R.png"}], "sets": {"ja": [{"set_number": "RD/KP23-JP058", "set_name": "Gias Charge of the Nova", "rarities": ["Rare"]}], "ko": [{"set_number": "RD/KP23-KR058", "set_name": "Gias Charge of the Nova", "rarities": ["Rare"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1159434}