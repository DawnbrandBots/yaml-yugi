{"konami_id": 22414, "name": {"en": "Dragon Knight of Dark", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "<ruby>\u9ed2<rt>\u304f\u308d</rt></ruby>\u306e<ruby>\u7adc<rt>\u308a\u3085\u3046</rt></ruby><ruby>\u9a0e<rt>\u304d</rt></ruby><ruby>\u58eb<rt>\u3057</rt></ruby>", "ja_romaji": "Kuro no Ry\u016bkishi", "ko": "\ud751\uc758 \uc6a9\uae30\uc0ac", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "summoning_condition": {"en": "This card's name becomes \"Dragon Knight of Darkness\" while in the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u5893\u5730\u306b\u3044\u308b\u3053\u306e\u30ab\u30fc\u30c9\u306e\u30ab\u30fc\u30c9\u540d\u306f\u300c\u6697\u9ed2\u306e\u7adc\u9a0e\u58eb\u300d\u306b\u306a\u308b\u3002", "ko": "\ubb18\uc9c0\uc5d0 \uc788\ub294 \uc774 \uce74\ub4dc\uc758 \uce74\ub4dc\uba85\uc740 \"\uc554\ud751\uc758 \uc6a9\uae30\uc0ac\"\uac00 \ub41c\ub2e4.", "zh-TW": null, "zh-CN": null}, "requirement": {"en": "If you have a Level 5 Dragon Type monster in your Graveyard, pay 500 LP.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306e\u5893\u5730\u306b\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30ec\u30d9\u30eb\uff15\uff0f\u30c9\u30e9\u30b4\u30f3\u65cf\uff09\u304c\u3044\u308b\u5834\u5408\u3001\uff15\uff10\uff10\uff2c\uff30\u3092\u6255\u3063\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0 \ubb18\uc9c0\uc5d0 \ubaac\uc2a4\ud130(\ub808\ubca8 5 / \ub4dc\ub798\uace4\uc871)\uac00 \uc788\uc744 \uacbd\uc6b0, 500 LP\ub97c \uc9c0\ubd88\ud558\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Destroy 1 face-up Level 6 or lower monster on your opponent's field. Then, you can Special Summon 1 Level 5 \"Dragon Knight of Darkness\" from your Graveyard face-up to your field.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u76f8\u624b\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u8868\u5074\u8868\u793a\u30e2\u30f3\u30b9\u30bf\u30fc\u