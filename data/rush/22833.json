{"konami_id": 22833, "name": {"en": "Voidalfr Buprestruve", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30f4\u30a9\u30a4\u30c9\u30a2\u30eb\u30f4\u30fb\u30bf\u30de\u30e0\u30b7\u30e5\u30c8\u30eb\u30fc\u30d9", "ja_romaji": "Voidoaruvu Tamamushutor\u016bbe", "ko": "\ubcf4\uc774\ub4dc\uc54c\ube0c \ud0c0\ub9c8\ubb34\uc288\ud2b8\ub8e8\ubca0", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "Send the top 2 cards of your Deck to the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30c7\u30c3\u30ad\u306e\u4e0a\u304b\u3089\u30ab\u30fc\u30c9\uff12\u679a\u3092\u5893\u5730\u3078\u9001\u3063\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\ub371 \uc704\uc5d0\uc11c \uce74\ub4dc 2\uc7a5\uc744 \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "This turn, this card's name becomes \"Voidalfr Heavenstar\". Then, you can add up to 2 \"Micronova\" from your Graveyard to your hand. You cannot activate the effects of non-Galaxy Type monsters until the end of this turn.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u306e\u30ab\u30fc\u30c9\u540d\u306f\u3053\u306e\u30bf\u30fc\u30f3\u3001\u300c\u30f4\u30a9\u30a4\u30c9\u30a2\u30eb\u30f4\u30fb\u30d8\u30f4\u30f3\u30b9\u30bf\u30fc\u300d\u306b\u306a\u308b\u3002\u305d\u306e\u5f8c\u3001\u81ea\u5206\u306e\u5893\u5730\u306e\u300c\u30de\u30a4\u30af\u30ed\u30ce\u30f4\u30a1\u300d\u3092\uff12\u679a\u307e\u3067\u9078\u3093\u3067\u624b\u672d\u306b\u52a0\u3048\u308b\u4e8b\u304c\u3067\u304d\u308b\u3002\u3053\u306e\u52b9\u679c\u306e\u767a\u52d5\u5f8c\u3001\u30bf\u30fc\u30f3\u7d42\u4e86\u6642\u307e\u3067\u81ea\u5206\u306f\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30ae\u30e3\u30e9\u30af\u30b7\u30fc\u65cf\u4ee5\u5916\uff09\u306e\u52b9\u679c\u3092\u767a\u52d5\u3067\u304d\u306a\u3044\u3002", "ko": "\uc774 \uce74\ub4dc\uc758 \uce74\ub4dc\uba85\uc740 \uc774 \ud134\