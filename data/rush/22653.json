{"konami_id": 22653, "name": {"en": "Scissor Hercules", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30b7\u30b6\u30fc\u30fb\u30d8\u30e9\u30af\u30ec\u30b9", "ja_romaji": "Shiz\u0101 Herakuresu", "ko": "\uc2dc\uc800 \ud5e4\ub77c\ud074\ub808\uc2a4", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "summoning_condition": {"en": "If you have a face-up EARTH Attribute Insect Type monster on your field, you can Normal Summon this card without Tributing.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u8868\u5074\u8868\u793a\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u5730\u5c5e\u6027\uff0f\u6606\u866b\u65cf\uff09\u304c\u3044\u308b\u5834\u5408\u3001\u3053\u306e\u30ab\u30fc\u30c9\u306f\u30ea\u30ea\u30fc\u30b9\u306a\u3057\u3067\u53ec\u559a\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0 \ud544\ub4dc\uc5d0 \uc55e\uba74 \ud45c\uc2dc \ubaac\uc2a4\ud130(\ub545 \uc18d\uc131 / \uace4\ucda9\uc871)\uac00 \uc788\uc744 \uacbd\uc6b0, \uc774 \uce74\ub4dc\ub294 \ub9b4\ub9ac\uc2a4 \uc5c6\uc774 \uc77c\ubc18 \uc18c\ud658\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "requirement": {"en": "During your Main Phase that you Normal or Special Summoned this card.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u3092\u53ec\u559a\u30fb\u7279\u6b8a\u53ec\u559a\u3057\u305f\u81ea\u5206\u30e1\u30a4\u30f3\u30d5\u30a7\u30a4\u30ba\u306b\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc774 \uce74\ub4dc\ub97c \uc77c\ubc18 \uc18c\ud658 / \ud2b9\uc218 \uc18c\ud658\ud55c \uc790\uc2e0 \uba54\uc778 \ud398\uc774\uc988\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Excavate the top 3 cards of your Deck. You can add 1 excavated Level 3 or 8 EARTH Attribute Insect Type monster to your hand. Place the other cards on the bottom of your Deck in any order.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306e\u30c7\u30c3\u30ad\u306e\u4e0a\u304b\u3089\u30ab\u30fc\u30c9\u3092\uff13\u679a\u3081\u304f\u308a\u3001\u304a\u4e92\u3044\u306b\u78ba\u8a8d\u3059\u308b\u3002\u81ea\u5206\u306f\u305d\u306e\u4e2d\u304b\u3089\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30ec\u30d9\u30eb\uff13\u30fb\uff18\uff0f\u5730\u5c5e\u6027\uff0f\u6606\u866b\u65cf\uff09\uff11\u4f53\u3092\u9078\u3093\u3067\u624b\u672d\u306b\u52a0\u3048\u308b\u4e8b\u304c\u3067\u304d\u308b\u3002\u6b8b\u308a\u306e\u30ab\u30fc\u30c9\u3092\u597d\u304d\u306a\u9806\u756a\u3067\u30c7\u30c3\u30ad\u306e\u4e0b\u306b\u623b\u3059\u3002", "ko": "\uc790\uc2e0\uc758 \ub371 \uc704\uc5d0\uc11c \uce74\ub4dc\ub97c 3\uc7a5 \ub118\uae30\uace0, \uc11c\ub85c \ud655\uc778\ud55c\ub2e4. \uc790\uc2e0\uc740 \uadf8 \uc911\uc5d0\uc11c \ubaac\uc2a4\ud130(\ub808\ubca8 3\u30fb8 / \ub545 \uc18d\uc131 / \uace4\ucda9\uc871) 1\uc7a5\uc744 \uace0\ub974\uace0 \ud328\uc5d0 \ub123\uc744 \uc218 \uc788\ub2e4. \ub0a8\uc740 \uce74\ub4dc\ub97c \uc88b\uc544\ud558\ub294 \uc21c\uc11c\ub300\ub85c \ub371 \uc544\ub798\ub85c \ub418\ub3cc\ub9b0\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Insect / Effect", "attribute": "EARTH", "level": 5, "atk": 1500, "def": 2000, "series": ["Moth"], "images": [{"index": 1, "image": "ScissorHercules-RDAP02-JP-SR.png"}], "sets": {"ja": [{"set_number": "RD/AP02-JP038", "set_name": "Advance Pack: Revenge Hearts", "rarities": ["Super Rare", "Secret Rare"]}], "ko": [{"set_number": "RD/AP02-KR038", "set_name": "Advance Pack: Revenge Hearts", "rarities": ["Super Rare", "Secret Rare"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1159932}