{"konami_id": 22625, "name": {"en": "Geefor the Defiant Soul", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "<ruby>\u53db<rt>\u306f\u3093</rt></ruby><ruby>\u9aa8<rt>\u3053\u3064</rt></ruby>\u306e\u30b8\u30fc\u30d5\u30a1", "ja_romaji": "Hankotsu no J\u012bfa", "ko": "\ubc18\uace8\uc758 \uc9c0\ud30c", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "summoning_condition": {"en": "This card's name becomes \"Gaigust the Defiant Soul\" while in the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u5893\u5730\u306b\u3044\u308b\u3053\u306e\u30ab\u30fc\u30c9\u306e\u30ab\u30fc\u30c9\u540d\u306f\u300c\u53db\u9aa8\u306e\u30ac\u30a4\u30ac\u30b9\u30c8\u300d\u306b\u306a\u308b\u3002", "ko": "\ubb18\uc9c0\uc5d0 \uc788\ub294 \uc774 \uce74\ub4dc\uc758 \uce74\ub4dc\uba85\uc740 \"\ubc18\uace8\uc758 \uac00\uc774\uac00\uc2a4\ud2b8\"\uac00 \ub41c\ub2e4.", "zh-TW": null, "zh-CN": null}, "requirement": {"en": "Send the top card of your Deck to the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30c7\u30c3\u30ad\u306e\u4e00\u756a\u4e0a\u306e\u30ab\u30fc\u30c9\u3092\u5893\u5730\u3078\u9001\u3063\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\ub371 \ub9e8 \uc704\uc758 \uce74\ub4dc\ub97c \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Increase this card's Level by 1 until the end of this turn. Then, you can select 1 Level 5 \"Gaigust the Defiant Soul\" in your Graveyard and add it to your hand or Special Summon it face-up to your field.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u306e\u30ec\u30d9\u30eb\u306f\u30bf\u30fc\u30f3\u7d42\u4e86\u6642\u307e\u3067\uff11\u4e0a\u304c\u308b\u3002\u305d\u306e\u5f8c\u3001\u81ea\u5206\u306e\u5893\u5730\u306e\u30ec\u30d9\u30eb\uff15\u306e\u300c\u53db\u9aa8\u306e\u30ac\u30a4\u30ac\u30b9\u30c8\u300d\uff11\u4f53\u3092\u9078\u3093\u3067\u624