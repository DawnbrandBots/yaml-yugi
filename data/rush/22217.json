{"konami_id": 22217, "name": {"en": "OuTerverSe Direct Driver", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "<ruby>\uff2f\uff34\uff33<rt>\u30a2\u30a6\u30bf\u30fc\u30d0\u30fc\u30b9</rt></ruby>\u30c0\u30a4\u30ec\u30af\u30c8\u30c9\u30e9\u30a4\u30d0\u30fc", "ja_romaji": "Aut\u0101b\u0101su Dairekuto Doraib\u0101", "ko": "OTS \ub2e4\uc774\ub809\ud2b8\ub4dc\ub77c\uc774\ubc84", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "summoning_condition": {"en": "This card's name becomes \"OuTerverSe\" while in the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u5893\u5730\u306b\u3044\u308b\u3053\u306e\u30ab\u30fc\u30c9\u306e\u30ab\u30fc\u30c9\u540d\u306f\u300c\uff2f\uff34\uff33\u300d\u306b\u306a\u308b\u3002", "ko": "\ubb18\uc9c0\uc5d0 \uc788\ub294 \uc774 \uce74\ub4dc\uc758 \uce74\ub4dc\uba85\uc740 \"OTS(\uc544\uc6b0\ud130\ubc84\uc2a4)\"\uac00 \ub41c\ub2e4.", "zh-TW": null, "zh-CN": null}, "requirement": {"en": "During the turn you Normal Summoned this card, send the top card of your Deck to the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u3092\u53ec\u559a\u3057\u305f\u30bf\u30fc\u30f3\u306b\u3001\u30c7\u30c3\u30ad\u306e\u4e00\u756a\u4e0a\u306e\u30ab\u30fc\u30c9\u3092\u5893\u5730\u3078\u9001\u3063\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc774 \uce74\ub4dc\ub97c \uc77c\ubc18 \uc18c\ud658\ud55c \ud134\uc5d0, \ub371 \ub9e8 \uc704\uc758 \uce74\ub4dc\ub97c \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "This card becomes Galaxy Type until the end of this turn. Then, you can choose 2 face-up Level 4 Galaxy Type Effect Monsters on your field. This turn, those monsters can attack directly, but you can only declare up to 2 attacks.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u306e\u7a2e\u65cf\u3092\u30bf\u30fc\u30f3\u7d42\u4e86\u6642\u307e\u3067\u30ae\u30e3\u30e9\u30af\u30b7\u30fc\u65cf\u306b\u3059\u308b\u3002\u305d\u306e\u5f8c\u3001\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u8868\u5074\u8868\u793a\u306e\u52b9\u679c\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30ec\u30d9\u30eb\uff14\uff0f\u30ae\u30e3\u30e9\u30af\u30b7\u30fc\u65cf\uff09\uff12\u4f53\u3092\u9078\u3076\u4e8b\u304c\u3067\u304d\u308b\u3002\u9078\u3093\u3060\u5834\u5408\u3001\u3053\u306e\u30bf\u30fc\u30f3\u3001\u305d\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u306f\u76f4\u63a5\u653b\u6483\u3067\u304d\u3001\u81ea\u5206\u306f\uff12\u56de\u307e\u3067\u3057\u304b\u653b\u6483\u5ba3\u8a00\u3067\u304d\u306a\u3044\u3002", "ko": "\uc774 \uce74\ub4dc\uc758 \uc885\uc871\uc744 \ud134 \uc885\ub8cc\uc2dc\uae4c\uc9c0 \uac24\ub7ed\uc2dc\uc871\uc73c\ub85c \ud55c\ub2e4. \uadf8 \ud6c4, \uc790\uc2e0 \ud544\ub4dc\uc758 \uc55e\uba74 \ud45c\uc2dc\uc778 \ud6a8\uacfc \ubaac\uc2a4\ud130(\ub808\ubca8 4 / \uac24\ub7ed\uc2dc\uc871) 2\uc7a5\uc744 \uace0\ub97c \uc218 \uc788\ub2e4. \uace0\ub978 \uacbd\uc6b0, \uc774 \ud134\uc5d0, \uadf8 \ubaac\uc2a4\ud130\ub294 \uc9c1\uc811 \uacf5\uaca9\ud560 \uc218 \uc788\uace0, \uc790\uc2e0\uc740 2\ud68c\uae4c\uc9c0\ubc16\uc5d0 \uacf5\uaca9 \uc120\uc5b8\ud560 \uc218 \uc5c6\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Dragon / Effect", "attribute": "WIND", "level": 4, "atk": 1200, "def": 800, "series": ["OuTerverSe"], "images": [{"index": 1, "image": "OuTerverSeDirectDriver-RDSJMP-JP-NPR.png"}], "sets": {"ja": [{"set_number": "RD/SJMP-JP056", "set_name": "Saiky\u014d Jump November 2025 promotional card", "rarities": ["Normal Parallel Rare"]}], "ko": [{"set_number": "RD/EV09-KR010", "set_name": "Rush Duel Event Pack 2026 Vol.1", "rarities": ["Common"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1144186}