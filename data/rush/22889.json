{"konami_id": 22889, "name": {"en": "Spinning Abduction", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30b9\u30d4\u30cb\u30f3\u30b0\u30fb\u30a2\u30d6\u30c0\u30af\u30b7\u30e7\u30f3", "ja_romaji": "Supiningu Abudakushon", "ko": "\uc2a4\ud53c\ub2dd \uc5b4\ube0c\ub355\uc158", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "You have 10 or more cards in your Deck.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306e\u30c7\u30c3\u30ad\u306e\u30ab\u30fc\u30c9\u304c\uff11\uff10\u679a\u4ee5\u4e0a\u306e\u5834\u5408\u306b\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0 \ub371\uc758 \uce74\ub4dc\uac00 10\uc7a5 \uc774\uc0c1\uc77c \uacbd\uc6b0\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Shuffle 6 DARK Attribute Galaxy Type monsters from your Graveyard into your Deck. Then, you can Special Summon 1 Level 7 or 8 Galaxy Type monster from your Graveyard face-up to your field.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306e\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u95c7\u5c5e\u6027\uff0f\u30ae\u30e3\u30e9\u30af\u30b7\u30fc\u65cf\uff09\uff16\u4f53\u3092\u9078\u3093\u3067\u30c7\u30c3\u30ad\u306b\u623b\u3059\u3002\u305d\u306e\u5f8c\u3001\u81ea\u5206\u306e\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30ec\u30d9\u30eb\uff17\u30fb\uff18\uff0f\u30ae\u30e3\u30e9\u30af\u30b7\u30fc\u65cf\uff09\uff11\u4f53\u3092\u9078\u3093\u3067\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u8868\u5074\u8868\u793a\u3067\u7279\u6b8a\u53ec\u559a\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0 \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130(\uc5b4\ub460 \uc18d\uc131 / \uac24\ub7ed\uc2dc\uc871) 6\uc7a5\uc744 \uace0\ub974\uace0 \ub371\uc73c\ub85c \ub418\ub3cc\ub9b0\ub2e4. \uadf8 \ud6c4, \uc790\uc2e0 \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130(\ub808\ubca8 7\u30fb8 / \uac24\ub7ed\uc2dc\uc871) 1\uc7a5\uc744 \uace0\ub974\uace0 \uc790\uc2e0 \ud544\ub4dc\uc5d0 \uc55e\uba74 \ud45c\uc2dc\ub85c \ud2b9\uc218 \uc18c\ud658\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Spell", "property": "Normal", "images": [{"index": 1, "image": "SpinningAbduction-RDKP24-JP-C.png"}], "sets": {"ja": [{"set_number": "RD/KP24-JP059", "set_name": "Overforce of the Abyss", "rarities": ["Common"]}], "ko": [{"set_number": "RD/KP24-KR059", "set_name": "Overforce of the Abyss", "rarities": ["Common"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1172969}