{"konami_id": 22888, "name": {"en": "The Shallow Grave", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "<ruby>\u6d45<rt>\u3042\u3055</rt></ruby>\u3059\u304e\u305f<ruby>\u5893<rt>\u306f\u304b</rt></ruby><ruby>\u7a74<rt>\u3042\u306a</rt></ruby>", "ja_romaji": null, "ko": "\uc595\uc740 \ubb34\ub364", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "Your opponent has 2 or less monsters on their field and a monster in their Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u76f8\u624b\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u304c\uff12\u4f53\u4ee5\u4e0b\u3067\u3001\u76f8\u624b\u306e\u5893\u5730\u306b\u30e2\u30f3\u30b9\u30bf\u30fc\u304c\u3044\u308b\u5834\u5408\u306b\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc0c1\ub300 \ud544\ub4dc\uc758 \ubaac\uc2a4\ud130\uac00 2\uc7a5 \uc774\ud558\uc774\uace0, \uc0c1\ub300 \ubb18\uc9c0\uc5d0 \ubaac\uc2a4\ud130\uac00 \uc788\uc744 \uacbd\uc6b0\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Special Summon 1 monster from your Graveyard to your field in face-down Defense Position. Then, your opponent can Special Summon 1 monster from their Graveyard to their field in face-down Defense Position.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306e\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3092\u9078\u3073\u3001\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u88cf\u5074\u5b88\u5099\u8868\u793a\u3067\u7279\u6b8a\u53ec\u559a\u3059\u308b\u3002\u305d\u306e\u5f8c\u3001\u76f8\u624b\u306f\u81ea\u8eab\u306e\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3092\u9078\u3093\u3067\u81ea\u8eab\u306e\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u88cf\u5074\u5b88\u5099\u8868\u793a\u3067\u7279\u6b8a\u53ec\u559a\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0 \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \uace0\ub974\uace0, \uc790\uc2e0 \ud544\ub4dc\uc5d0 \ub4b7\uba74 \uc218\ube44 \ud45c\uc2dc\ub85c \ud2b9\uc218 \uc18c\ud658\ud55c\ub2e4. \uadf8 \ud6c4, \uc0c1\ub300\ub294 \uc790\uc2e0 \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \uace0\ub974\uace0 \uc790\uc2e0 \ud544\ub4dc\uc5d0 \ub4b7\uba74 \uc218\ube44 \ud45c\uc2dc\ub85c \ud2b9\uc218 \uc18c\ud658\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Spell", "property": "Normal", "images": [{"index": 1, "image": "TheShallowGrave-RDKP24-JP-SR.png"}], "sets": {"ja": [{"set_number": "RD/KP24-JP058", "set_name": "Overforce of the Abyss", "rarities": ["Super Rare"]}], "ko": [{"set_number": "RD/KP24-KR058", "set_name": "Overforce of the Abyss", "rarities": ["Super Rare"]}]}, "is_translation_unofficial": {"text": {"en": true}}, "yugipedia_page_id": 1174206}