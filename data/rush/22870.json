{"konami_id": 22870, "name": {"en": "Luna Moonforce Dralia", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30eb\u30ca\u30e0\u30fc\u30f3\u30d5\u30a9\u30fc\u30b9\u30fb\u30c9\u30e9\u30ea\u30a2", "ja_romaji": "Runa M\u016bnf\u014dsu Doraria", "ko": "\ub8e8\ub098\ubb38\ud3ec\uc2a4 \ub4dc\ub77c\ub9ac\uc544", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "If the number of monsters in your opponent's Graveyard exceeds the number of monsters in your Graveyard, place 1 monster from your Graveyard on the bottom of the Deck.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u76f8\u624b\u306e\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u306e\u6570\u304c\u81ea\u5206\u306e\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u306e\u6570\u3088\u308a\u591a\u3044\u5834\u5408\u3001\u81ea\u5206\u306e\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3092\u30c7\u30c3\u30ad\u306e\u4e0b\u306b\u623b\u3057\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc0c1\ub300 \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130\uc758 \uc218\uac00 \uc790\uc2e0 \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130\uc758 \uc218\ubcf4\ub2e4 \ub9ce\uc744 \uacbd\uc6b0, \uc790\uc2e0 \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ub371 \uc544\ub798\ub85c \ub418\ub3cc\ub9ac\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Until the end of your opponent's next turn, this card gains ATK equal to [the difference between the number of monsters in both players' Graveyards] x 100, and it inflicts piercing battle damage.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u6b21\u306e\u76f8\u624b\u30bf\u30fc\u30f3\u7d42\u4e86\u6642\u307e\u3067\u3001\u3053\u306e\u30ab\u30fc\u30c9\u306e\u653b\u6483\u529b\u306f\uff3b\u304a\u4e92\u3044\u306e\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u306e\u6570\u306e\u5dee\uff3d\u00d7\uff11\uff10\uff10\u30a2\u30c3\u30d7\u3057\u3001\u305d\u306e\u653b\u6483\u306f\u8cab\u901a\u3059\u308b\u3002", "ko": "\ub2e4\uc74c \uc0c1\ub300 \ud134 \uc885\ub8cc\uc2dc\uae4c\uc9c0, \uc774 \uce74\ub4dc\uc758 \uacf5\uaca9\ub825\uc740 [\uc11c\ub85c\uc758 \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130\uc758 \uc218\uc758 \ucc28] \u00d7 100 \uc62c\ub9ac\uace0, \uadf8 \uacf5\uaca9\uc740 \uad00\ud1b5\ud55c\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Galaxy / Ritual / Effect", "attribute": "EARTH", "level": 9, "atk": 2900, "def": 2900, "series": ["Moonforce"], "images": [{"index": 1, "image": "LunaMoonforceDralia-RDKP24-JP-R.png", "illustration": "LunaMoonforceDralia-OW.png"}, {"index": 2, "image": "LunaMoonforceDralia-RDKP24-JP-ScR.png"}], "sets": {"ja": [{"set_number": "RD/KP24-JP040", "set_name": "Overforce of the Abyss", "rarities": ["Rare", "Secret Rare"]}], "ko": [{"set_number": "RD/KP24-KR040", "set_name": "Overforce of the Abyss", "rarities": ["Rare", "Secret Rare"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1163470}