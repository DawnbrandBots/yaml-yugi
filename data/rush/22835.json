{"konami_id": 22835, "name": {"en": "Voidalfr Antromeda", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30f4\u30a9\u30a4\u30c9\u30a2\u30eb\u30f4\u30fb\u30a2\u30f3\u30c8\u30ed\u30e1\u30c0", "ja_romaji": "Voidoaruvu Antoromeda", "ko": "\ubcf4\uc774\ub4dc\uc54c\ube0c \uc548\ud2b8\ub85c\uba54\ub2e4", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "summoning_condition": {"en": "If you have 3 or more Galaxy Type monsters in your Graveyard, you can Normal Summon this card without Tributing.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306e\u5893\u5730\u306b\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30ae\u30e3\u30e9\u30af\u30b7\u30fc\u65cf\uff09\u304c\uff13\u4f53\u4ee5\u4e0a\u3044\u308b\u5834\u5408\u3001\u3053\u306e\u30ab\u30fc\u30c9\u306f\u30ea\u30ea\u30fc\u30b9\u306a\u3057\u3067\u53ec\u559a\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0 \ubb18\uc9c0\uc5d0 \ubaac\uc2a4\ud130(\uac24\ub7ed\uc2dc\uc871)\uac00 3\uc7a5 \uc774\uc0c1 \uc788\uc744 \uacbd\uc6b0, \uc774 \uce74\ub4dc\ub294 \ub9b4\ub9ac\uc2a4 \uc5c6\uc774 \uc77c\ubc18 \uc18c\ud658\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "requirement": {"en": "Send the top card of your Deck to the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30c7\u30c3\u30ad\u306e\u4e00\u756a\u4e0a\u306e\u30ab\u30fc\u30c9\u3092\u5893\u5730\u3078\u9001\u3063\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\ub371 \ub9e8 \uc704\uc758 \uce74\ub4dc\ub97c \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "This turn, this face-up card can be treated as 2 Tributes for the Tribute Summon of a Galaxy Type monster in Attack Position. Then, you can add 1 \"Voidalfr Heavenstar\" from your Graveyard to your hand.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30bf\u30fc\u30f3\u3001\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30ae\u30e3\u30e9\u30af\u30b7\u30fc\u65cf\uff09\u3092\u653b\u6483\u8868\u793a\u3067\u30a2\u30c9\u30d0\u30f3\u30b9\u53ec\u559a\u3059\u308b\u5834\u5408\u3001\u8868\u5074\u8868\u793a\u306e\u3053\u306e\u30ab\u30fc\u30c9\u306f\uff12\u4f53\u5206\u306e\u30ea\u30ea\u30fc\u30b9\u306b\u3067\u304d\u308b\u3002\u3055\u3089\u306b\u3001\u81ea\u5206\u306e\u5893\u5730\u306e\u300c\u30f4\u30a9\u30a4\u30c9\u30a2\u30eb\u30f4\u30fb\u30d8\u30f4\u30f3\u30b9\u30bf\u30fc\u300d\uff11\u4f53\u3092\u9078\u3093\u3067\u624b\u672d\u306b\u52a0\u3048\u308b\u4e8b\u304c\u3067\u304d\u308b\u3002", "ko": "\uc774 \ud134\uc5d0, \ubaac\uc2a4\ud130(\uac24\ub7ed\uc2dc\uc871)\ub97c \uacf5\uaca9 \ud45c\uc2dc\ub85c \uc5b4\ub4dc\ubc34\uc2a4 \uc18c\ud658\ud560 \uacbd\uc6b0, \uc55e\uba74 \ud45c\uc2dc\uc778 \uc774 \uce74\ub4dc\ub294 2\uc7a5\ub9cc\ud07c\uc758 \ub9b4\ub9ac\uc2a4\ub85c \ud560 \uc218 \uc788\ub2e4. \ucd94\uac00\ub85c, \uc790\uc2e0 \ubb18\uc9c0\uc758 \"\ubcf4\uc774\ub4dc\uc54c\ube0c \ud5e4\ube10\uc2a4\ud0c0\" 1\uc7a5\uc744 \uace0\ub974\uace0 \ud328\uc5d0 \ub123\uc744 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Galaxy / Effect", "attribute": "EARTH", "level": 5, "atk": 1000, "def": 1700, "series": ["Voidalfr"], "images": [{"index": 1, "image": "VoidalfrAntromeda-RDKP24-JP-C.png"}], "sets": {"ja": [{"set_number": "RD/KP24-JP005", "set_name": "Overforce of the Abyss", "rarities": ["Common"]}], "ko": [{"set_number": "RD/KP24-KR005", "set_name": "Overforce of the Abyss", "rarities": ["Common"]}]}, "is_translation_unofficial": {"text": {"en": true}}, "yugipedia_page_id": 1174028}