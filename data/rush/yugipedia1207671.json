{"konami_id": null, "name": {"en": "Card Destruction", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "<ruby>\u624b<rt>\u3066</rt></ruby><ruby>\u672d<rt>\u3075\u3060</rt></ruby><ruby>\u62b9<rt>\u307e\u3063</rt></ruby><ruby>\u6bba<rt>\u3055\u3064</rt></ruby>", "ja_romaji": "Tefuda Massatsu", "ko": null, "ko_rr": null, "zh-TW": null, "zh-CN": null}, "text": {"en": "Each player with cards in their hand sends all Monster Cards from their hand to the Graveyard, then draws cards equal to [the number of cards each player sent to the Graveyard by this effect]. (If there are no more cards in the Deck while drawing, shuffle the cards in the Graveyard and place them in the Deck Zone, and draw the remaining number of cards.)", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u624b\u672d\u304c\u3042\u308b\u30d7\u30ec\u30a4\u30e4\u30fc\u306f\u3001\u624b\u672d\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u30ab\u30fc\u30c9\u3092\u5168\u3066\u5893\u5730\u3078\u9001\u308b\u3002\u305d\u306e\u5f8c\u3001\u5168\u54e1\u306f\uff3b\u3053\u306e\u52b9\u679c\u3067\u81ea\u8eab\u306e\u624b\u672d\u304b\u3089\u5893\u5730\u3078\u9001\u3089\u308c\u305f\u30ab\u30fc\u30c9\u306e\u6570\uff3d\u3060\u3051\u30c9\u30ed\u30fc\u3059\u308b\uff08\u30c9\u30ed\u30fc\u306e\u9014\u4e2d\u3067\u30c7\u30c3\u30ad\u306e\u30ab\u30fc\u30c9\u304c\u306a\u304f\u306a\u3063\u305f\u5834\u5408\u3001\u5893\u5730\u306b\u3042\u308b\u30ab\u30fc\u30c9\u3092\u30b7\u30e3\u30c3\u30d5\u30eb\u3057\u3066\u30c7\u30c3\u30ad\u30be\u30fc\u30f3\u306b\u7f6e\u304d\u3001\u6b8b\u308a\u306e\u679a\u6570\u3092\u30c9\u30ed\u30fc\u3059\u308b\uff09\u3002", "ko": null, "zh-TW": null, "zh-CN": null}, "card_type": "Spell", "property": "Normal", "cannot_be_used_in_official_duels": true, "images": [{"index": 1, "image": "CardDestruction-WWRP-JP-C.png"}], "sets": {}, "is_translation_unofficial": {"text": {"en": true}}, "yugipedia_page_id": 1207671}