es": [{"index": 1, "image": "Micronova-RDKP24-JP-C.png"}], "sets": {"ja": [{"set_number": "RD/KP24-JP044", "set_name": "Overforce of the Abyss", "rarities": ["Common"]}], "ko": [{"set_number": "RD/KP24-KR044", "set_name": "Overforce of the Abyss", "rarities": ["Common"]}]}, "is_translation_unofficial": {"text": {"en": true}}, "yugipedia_page_id": 1174034}