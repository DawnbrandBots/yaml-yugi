{"konami_id": 22864, "name": {"en": "Voidalfr Star Mayfly", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30f4\u30a9\u30a4\u30c9\u30a2\u30eb\u30f4\u30fb\u30b9\u30bf\u30fc\u30e1\u30a4\u30d5\u30e9\u30a4", "ja_romaji": "Voidoaruvu Sut\u0101meifurai", "ko": "\ubcf4\uc774\ub4dc\uc54c\ube0c \uc2a4\ud0c0\uba54\uc774\ud50c\ub77c\uc774", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "During your Main Phase that you Fusion Summoned this card, shuffle 3 Galaxy Type monsters from your Graveyard into the Deck, including a WATER Attribute monster.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u3092\u30d5\u30e5\u30fc\u30b8\u30e7\u30f3\u53ec\u559a\u3057\u305f\u81ea\u5206\u30e1\u30a4\u30f3\u30d5\u30a7\u30a4\u30ba\u306b\u3001\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u6c34\u5c5e\u6027\uff09\u3092\u542b\u3080\u81ea\u5206\u306e\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30ae\u30e3\u30e9\u30af\u30b7\u30fc\u65cf\uff09\uff13\u4f53\u3092\u30c7\u30c3\u30ad\u306b\u623b\u3057\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc774 \uce74\ub4dc\ub97c \ud4e8\uc804 \uc18c\ud658\ud55c \uc790\uc2e0 \uba54\uc778 \ud398\uc774\uc988\uc5d0, \ubaac\uc2a4\ud130(\ubb3c \uc18d\uc131)\ub97c \ud3ec\ud568\ud558\ub294 \uc790\uc2e0 \ubb18\uc9c0\uc758 \ubaac\uc2a4\ud130(\uac24\ub7ed\uc2dc\uc871) 3\uc7a5\uc744 \ub371\uc73c\ub85c \ub418\ub3cc\ub9ac\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Return up to 3 face-up Level 8 or lower monsters and/or face-down monsters from your opponent's field to the owner's hand. This turn, you can only attack with 1 monster.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u76f8\u624b\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u8868\u5074\u8868\u793a\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u30ec\u30d9\u30eb\uff18\u4ee5\u4e0b\uff09\u307e\u305f\u306f\u88cf\u5074\u8868\u793a\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\u5408\u8a08\uff13\u4f53\u307e\u3067\u9078\u3093\u3067\u6301\u3061\u4e3b\u306e\u624b\u672d\u306b\u623b\u3059\u3002\u3053\u306e\u30bf\u30fc\u30f3\u3001\u81ea\u5206\u306f\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3067\u3057\u304b\u653b\u6483\u3067\u304d\u306a\u3044\u3002", "ko": "\uc0c1\ub300 \ud544\ub4dc\uc758 \uc55e\uba74 \ud45c\uc2dc \ubaac\uc2a4\ud130(\ub808\ubca8 8 \uc774\ud558) \ub610\ub294 \ub4b7\uba74 \ud45c\uc2dc \ubaac\uc2a4\ud130\ub97c \ud569\uacc4 3\uc7a5\uae4c\uc9c0 \uace0\ub974\uace0 \uc8fc\uc778\uc758 \ud328\ub85c \ub418\ub3cc\ub9b0\ub2e4. \uc774 \ud134\uc5d0, \uc790\uc2e0\uc740 \ubaac\uc2a4\ud130 1\uc7a5\uc73c\ub85c\ubc16\uc5d0 \uacf5\uaca9\ud560 \uc218 \uc5c6\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Galaxy / Fusion / Effect", "attribute": "WATER", "level": 9, "atk": 3000, "def": 2400, "materials": {"en": "\"Voidalfr Heavenstar\" + 1 WATER Attribute monster", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u300c\u30f4\u30a9\u30a4\u30c9\u30a2\u30eb\u30f4\u30fb\u30d8\u30f4\u30f3\u30b9\u30bf\u30fc\u300d\uff0b\u30e2\u30f3\u30b9\u30bf\u30fc\uff08\u6c34\u5c5e\u6027\uff09", "ko": "\"\ubcf4\uc774\ub4dc\uc54c\ube0c \ud5e4\ube10\uc2a4\ud0c0\" \uff0b \ubaac\uc2a4\ud130(\ubb3c \uc18d\uc131)", "zh-TW": null, "zh-CN": null}, "series": ["Voidalfr"], "images": [{"index": 1, "image": "VoidalfrStarMayfly-RDKP24-JP-R.png"}], "sets": {"ja": [{"set_number": "RD/KP24-JP034", "set_name": "Overforce of the Abyss", "rarities": ["Rare", "Secret Rare"]}], "ko": [{"set_number": "RD/KP24-KR034", "set_name": "Overforce of the Abyss", "rarities": ["Rare", "Secret Rare"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1174032}