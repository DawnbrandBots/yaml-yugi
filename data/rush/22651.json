{"konami_id": 22651, "name": {"en": "Pulsating Cocoon of Evolution", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "<ruby>\u9f13<rt>\u3053</rt></ruby><ruby>\u52d5<rt>\u3069\u3046</rt></ruby>\u3059\u308b<ruby>\u9032<rt>\u3057\u3093</rt></ruby><ruby>\u5316<rt>\u304b</rt></ruby>\u306e<ruby>\u7e6d<rt>\u307e\u3086</rt></ruby>", "ja_romaji": "Kod\u014dsuru Shinka no Mayu", "ko": "\uace0\ub3d9\ud558\ub294 \uc9c4\ud654\uc758 \uace0\uce58", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "Send the top card of your Deck to the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30c7\u30c3\u30ad\u306e\u4e00\u756a\u4e0a\u306e\u30ab\u30fc\u30c9\u3092\u5893\u5730\u3078\u9001\u3063\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\ub371 \ub9e8 \uc704\uc758 \uce74\ub4dc\ub97c \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "This turn, this card's name becomes \"Cocoon of Evolution\". Then, you can Fusion Summon \"Perfectly Ultimate Great Moth\" by shuffling monsters from your field or Graveyard into the owner's Deck as material, including this card.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u306e\u30ab\u30fc\u30c9\u540d\u306f\u3053\u306e\u30bf\u30fc\u30f3\u3001\u300c\u9032\u5316\u306e\u7e6d\u300d\u306b\u306a\u308b\u3002\u305d\u306e\u5f8c\u3001\u3053\u306e\u30ab\u30fc\u30c9\u3092\u542b\u3080\u81ea\u5206\u306e\u30d5\u30a3\u30fc\u30eb\u30c9\u30fb\u5893\u5730\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\u7d20\u6750\u3068\u3057\u3066\u6301\u3061\u4e3b\u306e\u30c7\u30c3\u30ad\u306b\u623b\u3057\u3066\u300c\u7a76\u6975\u5b8c\u5168\u614b\u30fb\u30b0\u30ec\u30fc\u30c8\u30fb\u30e2\u30b9\u300d\u3092\u30d5\u30e5\u30fc\u30b8\u30e7\u30f3\u53ec\u559a\u3067\u304d\u308b\u3002", "ko": "\uc774 \uce74\ub4dc\uc758 \uce74\ub4dc\uba85\uc740 \uc774 \ud134\uc5d0, \"\uc9c4\ud654\uc758 \uace0\uce58\"\uac00