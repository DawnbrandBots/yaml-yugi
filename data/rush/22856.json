{"konami_id": 22856, "name": {"en": "Beast Blader", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30d3\u30fc\u30b9\u30c8\u30fb\u30d6\u30ec\u30a4\u30c0\u30fc", "ja_romaji": "B\u012bsuto Bureid\u0101", "ko": "\ube44\uc2a4\ud2b8 \ube14\ub808\uc774\ub354", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "Send the top 2 cards of your Deck to the Graveyard.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30c7\u30c3\u30ad\u306e\u4e0a\u304b\u3089\u30ab\u30fc\u30c9\uff12\u679a\u3092\u5893\u5730\u3078\u9001\u3063\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\ub371 \uc704\uc5d0\uc11c \uce74\ub4dc 2\uc7a5\uc744 \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "This card gains 600 ATK until the end of this turn. Then, you can send 1 card from your hand to the Graveyard. Then, if you sent a card to the Graveyard by this effect, you can change the battle position of 1 monster on your opponent's field.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u3053\u306e\u30ab\u30fc\u30c9\u306e\u653b\u6483\u529b\u306f\u30bf\u30fc\u30f3\u7d42\u4e86\u6642\u307e\u3067\uff16\uff10\uff10\u30a2\u30c3\u30d7\u3059\u308b\u3002\u305d\u306e\u5f8c\u3001\u81ea\u5206\u306e\u624b\u672d\uff11\u679a\u3092\u9078\u3093\u3067\u5893\u5730\u3078\u9001\u308b\u4e8b\u304c\u3067\u304d\u308b\u3002\u3053\u306e\u52b9\u679c\u3067\u5893\u5730\u3078\u9001\u3063\u305f\u5834\u5408\u3001\u3055\u3089\u306b\u76f8\u624b\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3092\u9078\u3093\u3067\u8868\u793a\u5f62\u5f0f\u3092\u5909\u66f4\u3067\u304d\u308b\u3002", "ko": "\uc774 \uce74\ub4dc\uc758 \uacf5\uaca9\ub825\uc740 \ud134 \uc885\ub8cc\uc2dc\uae4c\uc9c0 600 \uc62c\ub9b0\ub2e4. \uadf8 \ud6c4, \uc790\uc2e0\uc758 \ud328 1\uc7a5\uc744 \uace0\ub974\uace0 \ubb18\uc9c0\ub85c \ubcf4\ub0bc \uc218 \uc788\ub2e4. \uc774 \ud6a8\uacfc\ub85c \ubb18\uc9c0\ub85c \ubcf4\ub0c8\uc744 \uacbd\uc6b0, \ucd94\uac00\ub85c \uc0c1\ub300 \ud544\ub4dc\uc758 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \uace0\ub974\uace0 \ud45c\uc2dc \ud615\uc2dd\uc744 \ubcc0\uacbd\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Beast-Warrior / Effect", "attribute": "EARTH", "level": 4, "atk": 1000, "def": 900, "images": [{"index": 1, "image": "BeastBlader-RDKP24-JP-R.png"}], "sets": {"ja": [{"set_number": "RD/KP24-JP026", "set_name": "Overforce of the Abyss", "rarities": ["Rare", "Secret Rare"]}], "ko": [{"set_number": "RD/KP24-KR026", "set_name": "Overforce of the Abyss", "rarities": ["Rare", "Secret Rare"]}]}, "is_translation_unofficial": {"name": {"en": true}, "text": {"en": true}}, "yugipedia_page_id": 1170426}