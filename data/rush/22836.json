{"konami_id": 22836, "name": {"en": "Voidalfr Heavenstar", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u30f4\u30a9\u30a4\u30c9\u30a2\u30eb\u30f4\u30fb\u30d8\u30f4\u30f3\u30b9\u30bf\u30fc", "ja_romaji": "Voidoaruvu Hevunsut\u0101", "ko": "\ubcf4\uc774\ub4dc\uc54c\ube0c \ud5e4\ube10\uc2a4\ud0c0", "ko_rr": null, "zh-TW": null, "zh-CN": null}, "requirement": {"en": "If you have 10 or more cards in your Deck, shuffle 1 card from your Graveyard into the Deck.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306e\u30c7\u30c3\u30ad\u306e\u30ab\u30fc\u30c9\u304c\uff11\uff10\u679a\u4ee5\u4e0a\u306e\u5834\u5408\u3001\u81ea\u5206\u306e\u5893\u5730\u306e\u30ab\u30fc\u30c9\uff11\u679a\u3092\u30c7\u30c3\u30ad\u306b\u623b\u3057\u3066\u767a\u52d5\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0 \ub371\uc758 \uce74\ub4dc\uac00 10\uc7a5 \uc774\uc0c1\uc77c \uacbd\uc6b0, \uc790\uc2e0 \ubb18\uc9c0\uc758 \uce74\ub4dc 1\uc7a5\uc744 \ub371\uc73c\ub85c \ub418\ub3cc\ub9ac\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "effect": {"en": "Send 1 card from your hand to the Graveyard. Then, you can draw 1 card. If you do, you can add 1 \"Micronova Fusion\" from your Graveyard to your hand.", "de": null, "es": null, "fr": null, "it": null, "pt": null, "ja": "\u81ea\u5206\u306e\u624b\u672d\uff11\u679a\u3092\u9078\u3093\u3067\u5893\u5730\u3078\u9001\u308b\u3002\u305d\u306e\u5f8c\u3001\u81ea\u5206\u306f\uff11\u679a\u30c9\u30ed\u30fc\u3067\u304d\u308b\u3002\u30c9\u30ed\u30fc\u3057\u305f\u5834\u5408\u3001\u3055\u3089\u306b\u81ea\u5206\u306e\u5893\u5730\u306e\u300c\u30de\u30a4\u30af\u30ed\u30ce\u30f4\u30a1\u30fb\u30d5\u30e5\u30fc\u30b8\u30e7\u30f3\u300d\uff11\u679a\u3092\u9078\u3093\u3067\u624b\u672d\u306b\u52a0\u3048\u308b\u4e8b\u304c\u3067\u304d\u308b\u3002", "ko": "\uc790\uc2e0\uc758 \ud328 1\uc7a5\uc744 \uace0\ub974\uace0 \ubb18\uc9c0\ub85c \ubcf4\ub0b8\ub2e4. \uadf8 \ud6c4, \uc790\uc2e0\uc740 1\uc7a5 \ub4dc\ub85c\uc6b0\ud560 \uc218 \uc788\ub2e4. \ub4dc\ub85c\uc6b0\ud588\uc744 \uacbd\uc6b0, \ucd94\uac00\ub85c \uc790\uc2e0 \ubb18\uc9c0\uc758 \"\ub9c8\uc774\ud06c\ub85c\ub178\ubc14 \ud4e8\uc804\" 1\uc7a5\uc744 \uace0\ub974\uace0 \ud328\uc5d0 \ub123\uc744 \uc218 \uc788\ub2e4.", "zh-TW": null, "zh-CN": null}, "card_type": "Monster", "monster_type_line": "Galaxy / Effect", "attribute": "FIRE", "level": 7, "atk": 2400, "def": 1600, "series": ["Voidalfr"], "images": [{"index": 1, "image": "VoidalfrHeavenstar-RDKP24-JP-R.png"}], "sets": {"ja": [{"set_number": "RD/KP24-JP006", "set_name": "Overforce of the Abyss", "rarities": ["Rare", "Secret Rare"]}], "ko": [{"set_number": "RD/KP24-KR006", "set_name": "Overforce of the Abyss", "rarities": ["Rare", "Secret Rare"]}]}, "is_translation_unofficial": {"text": {"en": true}}, "yugipedia_page_id": 1173819}